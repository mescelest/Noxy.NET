@inherits BaseInputTextual<string>

<input @attributes="AdditionalAttributes" class="@CssClass" id="@IDCurrent" Name="@GetName()" type="@TypeCurrent" size="@SizeCurrent" value="@ValueInternal" @onchange="OnValueChange" @oninput="OnValueInput"/>

@code {

    [Parameter]
    public WebFormInputTextTypeEnum? Type { get; set; }
    private string TypeCurrent => (Type ?? WebFormInputTextTypeEnum.Text).ToText();

}

