@inherits BaseInput<TValue?>
@typeparam TValue

<input @attributes="AdditionalAttributes" class="@CssClass" id="@IDCurrent" name="@GetName()" type="checkbox" checked="@CheckedCurrent" @onchange="OnInputChange"/>

@code {

    [Parameter, EditorRequired]
    public required TValue Option { get; set; }

    [Parameter]
    public bool? Checked { get; set; }
    private bool CheckedCurrent => Checked ?? EqualityComparer<TValue>.Default.Equals(Value, Option);

    private void OnInputChange(ChangeEventArgs args)
    {
        OnChange.InvokeAsync(args);
        NotifyChange(GetEventValue(args) ? (TValue?)Option : default);
    }

    private static bool GetEventValue(ChangeEventArgs args)
    {
        if (args.Value is bool parsed) return parsed;
        return bool.TryParse(args.Value?.ToString(), out bool value) && value;
    }

}
