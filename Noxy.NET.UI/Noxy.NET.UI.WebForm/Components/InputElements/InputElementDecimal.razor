@inherits BaseInputTextual<decimal?>

<input @attributes="AdditionalAttributes" class="@CssClass" ID="@IDCurrent" Name="@GetName()" type="tel" size="@SizeCurrent" value="@ValueInternal" inputmode="numeric" @onchange="OnValueChange" @oninput="OnValueInput"/>

@code {

    protected override decimal? GetParsedValue(string value)
    {
        return decimal.TryParse(value, NumberStyles.Number, CultureInfo.InvariantCulture, out decimal parsed) ? parsed : null;
    }

}
