@inherits BaseInputTextual<string>

<textarea @attributes="AdditionalAttributes" class="@CssClass" id="@IDCurrent" name="@GetName()" cols="@SizeCurrent" rows="@RowsCurrent" @onchange="OnValueChange" @oninput="OnValueInput">
    @ValueInternal
</textarea>

@code {

    [Parameter]
    public int? Rows { get; set; }
    private int RowsCurrent => Rows ?? 6;

    protected override string? GetParsedValue(string value)
    {
        return value;
    }

}
