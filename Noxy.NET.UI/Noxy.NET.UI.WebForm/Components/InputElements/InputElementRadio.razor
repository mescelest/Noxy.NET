@inherits BaseInput<TOption>
@typeparam TOption

<input @attributes="AdditionalAttributes" class="@CssClass" id="@IDCurrent" name="@GetName()" type="radio" checked="@Checked" @onclick="OnInputClick" @onchange="OnInputChange"/>

@code {

    [Parameter, EditorRequired]
    public required TOption Option { get; set; }

    [Parameter]
    public bool? Checked { get; set; }
    private bool CheckedCurrent => Checked ?? EqualityComparer<TOption>.Default.Equals(Value, Option);

    private bool _internalNullable;

    protected override void OnInitialized()
    {
        base.OnInitialized();

        _internalNullable = Nullable.GetUnderlyingType(typeof(TOption)) != null;
    }

    private void OnInputClick(MouseEventArgs args)
    {
        if (!_internalNullable || !CheckedCurrent) return;

        NotifyChange(default);
    }

    private void OnInputChange(ChangeEventArgs args)
    {
        OnChange.InvokeAsync(args);
        NotifyChange(Option);
    }

}

