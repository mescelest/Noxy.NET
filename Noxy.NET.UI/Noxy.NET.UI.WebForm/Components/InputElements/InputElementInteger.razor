@inherits BaseInputTextual<int?>

<input @attributes="AdditionalAttributes" class="@CssClass" ID="@IDCurrent" Name="@GetName()" type="tel" size="@SizeCurrent" value="@ValueInternal" inputmode="numeric" @onchange="OnValueChange" @oninput="OnValueInput"/>

@code {

    protected override int? GetParsedValue(string value)
    {
        return int.TryParse(value, NumberStyles.Integer, CultureInfo.InvariantCulture, out int parsed) ? parsed : null;
    }

}
