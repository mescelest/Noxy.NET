@inherits BaseInput<TOption>
@implements INotifyInputChanged
@typeparam TOption

<select @attributes="AdditionalAttributes" class="@CssClass" id="@IDCurrent" name="@GetName()" @onchange="OnInputChange">
    @for (int i = 0; i < _cacheList.Length; i++)
    {
        TOption item = _cacheList[i];

        <option value="@i" selected="@IsChecked(item)">
            @ChildContent(item)
        </option>
    }
</select>

@code {

    [Parameter, EditorRequired]
    public HashSet<TOption> OptionList { get; set; }

    [Parameter, EditorRequired]
    public RenderFragment<TOption> ChildContent { get; set; }

    [Parameter]
    public EventCallback<ChangeEventArgs> OnChange { get; set; }

    private TOption[] _cacheList = [];

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        if (_cacheList.Length == OptionList.Count && _cacheList.SequenceEqual(OptionList)) return;
        _cacheList = OptionList.ToArray();
    }

    private bool IsChecked(TOption option) => EqualityComparer<TOption>.Default.Equals(Value, option);

    private void OnInputChange(ChangeEventArgs args)
    {
        if (!int.TryParse(args.Value?.ToString(), out int parsed)) return;

        OnChange.InvokeAsync(args);
        NotifyChange(OptionList.ElementAt(parsed));
    }

}