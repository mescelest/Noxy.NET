@inherits BaseInputTextual<string>

<input @attributes="AdditionalAttributes" class="@CssClass" ID="@IDCurrent" Name="@GetName()" type="password" size="@SizeCurrent" autocomplete="@AutocompleteCurrent" value="@ValueInternal" @onchange="OnValueChange" @oninput="OnValueInput"/>

@code {

    [Parameter]
    public WebFormInputFieldPasswordAutocompleteEnum? Autocomplete { get; set; }
    private string? AutocompleteCurrent => Autocomplete?.ToAttributeValue();

    protected override string? GetParsedValue(string value)
    {
        return value;
    }

}
