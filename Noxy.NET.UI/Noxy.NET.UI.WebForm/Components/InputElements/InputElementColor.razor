@inherits BaseInput<string?>
@implements INotifyInputChanged

<input @attributes="AdditionalAttributes" class="@CssClass" id="@IDCurrent" name="@GetName()" type="color" alpha="@Alpha" value="@Value" @onchange="OnInputChange"/>

@code {

    [Parameter]
    public bool? Alpha { get; set; }

    [Parameter]
    public EventCallback<ChangeEventArgs> OnChange { get; set; }

    private void OnInputChange(ChangeEventArgs args)
    {
        OnChange.InvokeAsync(args);
        NotifyChange(GetEventValue(args));
    }

    private static string GetEventValue(ChangeEventArgs args)
    {
        return args.Value?.ToString() ?? string.Empty;
    }

}
