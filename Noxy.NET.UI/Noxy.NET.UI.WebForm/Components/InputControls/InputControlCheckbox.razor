@inherits BaseInput<TOption?>
@typeparam TOption

<TemplateInputControlCheckbox Visual="@Visual" For="@IDCurrent" Checked="@Checked" Disabled="@Disabled">
    <InputElementCheckbox TOption="TOption" @attributes="@AdditionalAttributes" class="@CssClass" ID="@IDCurrent" Name="@GetName()" Option="Option" Value="Value" ValueChanged="ValueChanged" ValueExpression="ValueExpression"/>

    @ChildContent
</TemplateInputControlCheckbox>

@code {

    [Parameter, EditorRequired]
    public TOption Option { get; set; }

    [Parameter, EditorRequired]
    public RenderFragment ChildContent { get; set; }

    [Parameter]
    public RenderFragment<bool>? Visual { get; set; }

    [Parameter]
    public bool? Disabled { get; set; }

    private bool Checked => EqualityComparer<TOption>.Default.Equals(Value, Option);

}
