@typeparam TOption
@inherits BaseInput<TOption?>

<label class="@CssClass" for="@IDCurrent" disabled="@Disabled">
    @if (Visual != null)
    {
        @Visual(Checked)
    }
    else
    {
        <div class="visual" checked="@Checked">
            <span class="tick">✔</span>
        </div>
    }

    <InputElementCheckbox TOption="TOption" @attributes="@AdditionalAttributes" ID="@IDCurrent" Name="@GetName()" Option="Option" Value="Value" ValueChanged="ValueChanged" ValueExpression="ValueExpression"/>

    @ChildContent   
</label>

@code {

    [Parameter, EditorRequired]
    public TOption Option { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public RenderFragment<bool?>? Visual { get; set; }

    [Parameter]
    public bool? Disabled { get; set; }

    private bool Checked => EqualityComparer<TOption>.Default.Equals(Value, Option);

}
