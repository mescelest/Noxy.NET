@inherits BaseInput<string>
@implements IBaseInputTextual

<TemplateInputControlTextual>
    <InputElementPassword @attributes="@AdditionalAttributes" class="@CssClass" ID="@IDCurrent" Name="@GetName()" Autocomplete="@Autocomplete" Size="Size" OnInputDelay="OnInputDelay" Value="@Value" ValueChanged="ValueChanged"
                          ValueExpression="ValueExpression"/>
</TemplateInputControlTextual>

@code {

    [Parameter]
    public WebFormInputElementPasswordAutocompleteEnum? Autocomplete { get; set; }

    [Parameter]
    public int? Size { get; set; }

    [Parameter]
    public int? OnInputDelay { get; set; }

}
