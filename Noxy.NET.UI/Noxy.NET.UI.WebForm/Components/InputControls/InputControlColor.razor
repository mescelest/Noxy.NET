@inherits BaseInput<BaseColor>

<div @attributes="AdditionalAttributes" class="@CssClass" disabled="@Disabled" style="anchor-scope: @_anchor;">
    <div class="input-group">
        <InputControlText @attributes="AdditionalAttributes" class="input" ID="@IDCurrent" Name="@GetName()" OnInputDelay="500" @bind-Value:get="ValueString" @bind-Value:set="SetValue"/>

        <div popovertarget="@_popover" class="custom-color-preview-btn" style="anchor-name: @_anchor; background-color: @ValueString;">
            <span class="sr-only">Choose Color</span>
        </div>
    </div>

    <div id="@_popover" popover="auto" class="custom-color-dropdown" style="position-anchor: @_anchor;">

        <div class="custom-dropdown-content">
            <h4>Advanced Color Engine</h4>
            <p>Active Hex: <code>@ValueString</code></p>

            <div class="palette-grid">
                <button type="button" @onclick='() => SetValue("#FF5733")' style="background:#FF5733"></button>
                <button type="button" @onclick='() => SetValue("#33FF57")' style="background:#33FF57"></button>
                <button type="button" @onclick='() => SetValue("#3357FF")' style="background:#3357FF"></button>
            </div>
        </div>
    </div>
</div>

@code {

    [Parameter, EditorRequired]
    public bool? Disabled { get; set; }

    private string _anchor = string.Empty;
    private string _popover = string.Empty;

    private string ValueString => Value?.ToCssString() ?? string.Empty;

    protected override void OnInitialized()
    {
        base.OnInitialized();

        _anchor = $"--color-anchor-{UUIDCode}";
        _popover = $"color-popover-{UUIDCode}";
    }

    private void SetValue(string? value)
    {
        if (BaseColor.TryParseCssColor(value, out BaseColor? color))
        {
            NotifyChange(color);
        }
    }

}