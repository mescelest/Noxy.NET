@inject IJSRuntime JS
@inherits BaseInput<BaseColor>
@implements IAsyncDisposable

<div @attributes="AdditionalAttributes" class="@CssClass" disabled="@Disabled">
    <div class="control">
        <InputControlText @attributes="AdditionalAttributes" class="input" ID="@IDCurrent" Name="@GetName()" OnInputDelay="500" @bind-Value:get="ValueString" @bind-Value:set="SetValue"/>

        <button class="preview" popovertarget="@_popover" style="background-color: @ValueString;"></button>
    </div>

    <div id="@_popover" popover class="popover">
        <div class="content">
            <div @ref="_windowRef" class="color-window" style="@GetWindowStyle()"></div>

            <InputElementRange class="color-scroll-hue" Min="0" Max="359" Step="1"
                               @bind-Value:get="GetHueDouble()" @bind-Value:set="SetHueFromDouble"/>

            <div class="color-input-list">
                <InputControlText class="color-red" Size="4" @bind-Value:get="@GetRedString()" @bind-Value:set="SetRedFromString"/>
                <InputControlText class="color-green" Size="4" @bind-Value:get="@GetGreenString()" @bind-Value:set="SetGreenFromString"/>
                <InputControlText class="color-blue" Size="4" @bind-Value:get="@GetBlueString()" @bind-Value:set="SetBlueFromString"/>
                <InputControlText class="color-alpha" Size="4" @bind-Value:get="GetAlphaString()" @bind-Value:set="SetAlphaFromString"/>
            </div>

            <div class="color-switch"></div>
            <div class="color-palette"></div>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public bool? Disabled { get; set; }

    private ElementReference _windowRef;
    private string _anchor = string.Empty;
    private string _popover = string.Empty;

    private IJSObjectReference? _dragInstance;
    private DotNetObjectReference<InputControlColor>? _dotNetHelper;

    private double? _hue;
    private RgbColor _localColor = new(0, 0, 0);
    private HsvColor? _activeDraftColor;

    private RgbColor CurrentRgb => _activeDraftColor?.ToRgb() ?? _localColor;

    private string ValueString => CurrentRgb.ToCssString();

    protected override void OnInitialized()
    {
        base.OnInitialized();
        _anchor = $"--color-anchor-{UUIDCode}";
        _popover = $"popover-{UUIDCode}";
    }

    protected override async Task OnAfterFirstRenderAsync()
    {
        await base.OnAfterFirstRenderAsync();

        await using IJSObjectReference module = await JS.InvokeAsync<IJSObjectReference>("import", $"./_content/{Constants.AssemblyNameUIWebForm}/Components/InputControls/{ComponentName}.razor.js");

        _dotNetHelper = DotNetObjectReference.Create(this);
        _dragInstance = await module.InvokeAsync<IJSObjectReference>("init", _windowRef, _dotNetHelper);
    }

    private string GetWindowStyle()
    {
        double currentHue = _activeDraftColor?.Hue ?? _hue ?? 0.0;
        return $"background-image: linear-gradient(to top, #000, transparent), linear-gradient(to right, #fff, transparent); background-color: hsl({currentHue} 100% 50%);";
    }

    private void SetValue(string? value)
    {
        if (BaseColor.TryParseCssColor(value, out BaseColor? color))
        {
            NotifyChange(color);
        }
    }

    private double GetHueDouble() => _activeDraftColor?.Hue ?? _hue ?? 0.0;
    private string GetRedString() => CurrentRgb.Red.ToString();
    private string GetGreenString() => CurrentRgb.Green.ToString();
    private string GetBlueString() => CurrentRgb.Blue.ToString();
    private string GetAlphaString() => CurrentRgb.Alpha.ToString("0.00", CultureInfo.InvariantCulture);

    private void SetHueFromDouble(double? value)
    {
        _hue = value;
        int integerHue = (int)Math.Round(_hue ?? 0.0);

        if (_activeDraftColor is not null)
        {
            _activeDraftColor = new(integerHue, _activeDraftColor.Saturation, _activeDraftColor.Value, _activeDraftColor.Alpha);
        }
        else
        {
            var hsv = _localColor.ToHsv();
            _localColor = new HsvColor(integerHue, hsv.Saturation, hsv.Value, hsv.Alpha).ToRgb();
            NotifyChange(_localColor);
        }
    }

    private void SetRedFromString(string? value)
    {
        int.TryParse(value, out int r);
        UpdateLocalColor(Math.Clamp(r, 0, 255), null, null, null);
    }

    private void SetGreenFromString(string? value)
    {
        int.TryParse(value, out int g);
        UpdateLocalColor(null, Math.Clamp(g, 0, 255), null, null);
    }

    private void SetBlueFromString(string? value)
    {
        int.TryParse(value, out int b);
        UpdateLocalColor(null, null, Math.Clamp(b, 0, 255), null);
    }

    private void SetAlphaFromString(string? value)
    {
        if (double.TryParse(value, NumberStyles.Any, CultureInfo.InvariantCulture, out double parsedAlpha))
        {
            UpdateLocalColor(null, null, null, Math.Clamp(parsedAlpha, 0.0, 1.0));
        }
    }

    private void UpdateLocalColor(int? r, int? g, int? b, double? a)
    {
        RgbColor current = CurrentRgb;

        int newR = r ?? current.Red;
        int newG = g ?? current.Green;
        int newB = b ?? current.Blue;
        double newA = a ?? current.Alpha;
        RgbColor updated = new(newR, newG, newB, newA);

        if (_activeDraftColor is not null)
        {
            _activeDraftColor = updated.ToHsv();
        }
        else
        {
            _localColor = updated;
            _hue = _localColor.ToHsv().Hue;
            NotifyChange(_localColor);
        }
    }

    [JSInvokable]
    public async Task UpdateColorPreviewFromJs(double saturationPercentage, double valuePercentage)
    {
        int saturation = (int)Math.Round(saturationPercentage);
        int value = (int)Math.Round(valuePercentage);
        int currentHueInteger = (int)Math.Round(_activeDraftColor?.Hue ?? _hue ?? 0.0);

        _activeDraftColor = new(currentHueInteger, saturation, value, CurrentRgb.Alpha);

        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnDragEnd()
    {
        if (_activeDraftColor is null) return;

        _localColor = _activeDraftColor.ToRgb();
        _hue = _activeDraftColor.Hue;
        NotifyChange(_localColor);

        _activeDraftColor = null;
        InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_dragInstance is not null)
            {
                await _dragInstance.InvokeVoidAsync("dispose");
                await _dragInstance.DisposeAsync();
            }

            _dotNetHelper?.Dispose();
        }
        catch (JSDisconnectedException)
        {
        }
    }
}