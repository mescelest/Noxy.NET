@inherits BaseInputGroup<TOption>
@typeparam TOption

<div @attributes="AdditionalAttributes" class="@CssClass">
    <TemplateInputGroup For="@IDCurrent" DisplayName="@DisplayNameCurrent" Description="@DescriptionCurrent" ErrorList="ErrorList">
        @{
            bool isChecked = EqualityComparer<TOption>.Default.Equals(Value, Option);
            InputElementRadioScope<TOption> context = new(IDCurrent, GetName(), isChecked, Option, Value, ValueChanged, ValueExpression);
            if (Control != null)
            {
                @Control(context)
            }
            else
            {
                <InputVisualRadio Checked="@context.Checked"/>
                <InputElementRadio @attributes="InputAttributes" ID="@context.ID" Name="@context.Name" Option="@context.Option"
                                   Value="@context.Value" ValueChanged="@context.ValueChanged" ValueExpression="@context.ValueExpression"/>
            }
        }

        @ChildContent
    </TemplateInputGroup>
</div>

@code {

    [Parameter, EditorRequired]
    public TOption Option { get; set; }

    [Parameter, EditorRequired]
    public RenderFragment ChildContent { get; set; }

    [Parameter]
    public RenderFragment<InputElementRadioScope<TOption>>? Control { get; set; }

}
