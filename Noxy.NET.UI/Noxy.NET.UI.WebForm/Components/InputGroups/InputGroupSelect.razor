@inherits BaseInputGroup<TValue>
@typeparam TValue

<div @attributes="AdditionalAttributes" class="@CssClass">
    <TemplateInputGroup For="@UUIDCode" DisplayName="@DisplayNameCurrent" Description="@DescriptionCurrent" ErrorList="ErrorList">
        <InputElementSelect @attributes="InputAttributes" TValue="TValue" ID="@IDCurrent" Name="@GetName()" OptionList="OptionList" ChildContent="ChildContent"
                            Value="Value" ValueChanged="ValueChanged" ValueExpression="ValueExpression"/>
    </TemplateInputGroup>
</div>

@code {

    [Parameter, EditorRequired]
    public required RenderFragment<TValue?> ChildContent { get; set; }

    [Parameter, EditorRequired]
    public required HashSet<TValue> OptionList { get; set; }

} 
