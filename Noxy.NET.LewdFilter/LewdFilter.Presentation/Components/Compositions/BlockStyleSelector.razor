@inject IDispatcher Dispatcher
@inject IStateSelection<FilterFeatureState, FilterBlock> BlockSelection
@inject IStateSelection<FilterFeatureState, ImmutableDictionary<FilterColorTypeEnum, IReadOnlyList<FilterColor>>> ColorCollectionSelection
@inherits FluxorElementComponent

<div @attributes="AdditionalAttributes" class="@CssClass">

    <FormField Label="Text Color" For="@TextColorId">
        <InputControlSelect TOption="FilterColor" class="text-color" ID="@TextColorId" Name="@TextColorId" OptionList="TextFilterColorSet" @bind-Value:get="Block.TextColor" @bind-Value:set="SetTextColor">
            @GetColorName(context)
        </InputControlSelect>
    </FormField>

    <FormField Label="Border Color" For="@BorderId">
        <InputControlSelect TOption="FilterColor" class="border-color" ID="@BorderId" Name="@BorderId" OptionList="BorderFilterColorSet" @bind-Value:get="Block.BorderColor" @bind-Value:set="SetBorderColor">
            @GetColorName(context)
        </InputControlSelect>
    </FormField>

    <FormField Label="Background Color" For="@BackgroundColorId">
        <InputControlSelect TOption="FilterColor" class="background-color" ID="@BackgroundColorId" Name="@BackgroundColorId" OptionList="BackgroundFilterColorSet" @bind-Value:get="Block.BackgroundColor" @bind-Value:set="SetBackgroundColor">
            @GetColorName(context)
        </InputControlSelect>
    </FormField>

    <FormField Label="@($"Font Size ({FontSize})")" For="@FontSizeId">
        <InputElementRange class="font-size" ID="@FontSizeId" Min="18" Max="45" @bind-Value:get="FontSize" @bind-Value:set="SetFontSize"/>
    </FormField>

    <FormField Label="Beam Effect" For="@PlayEffectId">
        <InputControlBeamEffect class="beam-effect" ID="@PlayEffectId" Name="@PlayEffectId" @bind-Value:get="Block.PlayEffect" @bind-Value:set="SetPlayEffect"/>
    </FormField>

    <FormField Label="Minimap Icon" For="@MinimapIconId">
        <InputControlMinimapIcon class="minimap-icon" ID="@MinimapIconId" Name="@MinimapIconId" @bind-Value:get="Block.MinimapIcon" @bind-Value:set="SetMinimapIcon"/>
    </FormField>

</div>

@code {

    [Parameter, EditorRequired]
    public Guid GroupId { get; set; }

    [Parameter, EditorRequired]
    public Guid BlockId { get; set; }

    private FilterBlock Block => BlockSelection.Value;
    private double? FontSize => Block.FontSize.HasValue ? (double)Block.FontSize.Value : 32;

    private string TextColorId => $"text-color-{GroupId}-{BlockId}";
    private string BackgroundColorId => $"background-color-{GroupId}-{BlockId}";
    private string BorderId => $"border-color-{GroupId}-{BlockId}";
    private string FontSizeId => $"font-size-slider-{GroupId}-{BlockId}";
    private string PlayEffectId => $"play-effect-{GroupId}-{BlockId}";
    private string MinimapIconId => $"minimap-icon-{GroupId}-{BlockId}";

    private HashSet<FilterColor?> TextFilterColorSet => GetColorsForType(FilterColorTypeEnum.Text);
    private HashSet<FilterColor?> BackgroundFilterColorSet => GetColorsForType(FilterColorTypeEnum.Background);
    private HashSet<FilterColor?> BorderFilterColorSet => GetColorsForType(FilterColorTypeEnum.Border);

    protected override void OnInitialized()
    {
        base.OnInitialized();

        BlockSelection.Select(FilterFeatureState.SelectBlock(GroupId, BlockId));
        ColorCollectionSelection.Select(FilterFeatureState.SelectCustomColorList());
    }

    private HashSet<FilterColor?> GetColorsForType(FilterColorTypeEnum type)
    {
        ImmutableDictionary<FilterColorTypeEnum, IReadOnlyList<FilterColor>>? collection = ColorCollectionSelection.Value;
        if (collection == null || !collection.TryGetValue(type, out IReadOnlyList<FilterColor>? list))
        {
            return [null];
        }

        return [null, .. list];
    }

    private void SetTextColor(FilterColor? value) => UpdateBlockColor(FilterColorTypeEnum.Text, value);
    private void SetBackgroundColor(FilterColor? value) => UpdateBlockColor(FilterColorTypeEnum.Background, value);
    private void SetBorderColor(FilterColor? value) => UpdateBlockColor(FilterColorTypeEnum.Border, value);

    private void UpdateBlockColor(FilterColorTypeEnum type, FilterColor? color)
    {
        FilterBlock updatedBlock = type switch
        {
            FilterColorTypeEnum.Text => Block with { TextColor = color },
            FilterColorTypeEnum.Background => Block with { BackgroundColor = color },
            FilterColorTypeEnum.Border => Block with { BorderColor = color },
            _ => throw new ArgumentOutOfRangeException(nameof(type), type, null)
        };

        DispatchUpdate(updatedBlock);
    }

    private void SetFontSize(double? value) => DispatchUpdate(Block with { FontSize = value.HasValue ? (int)value.Value : 32 });
    private void SetPlayEffect(FilterBeamEffect? value) => DispatchUpdate(Block with { PlayEffect = value });
    private void SetMinimapIcon(FilterMinimapIcon? value) => DispatchUpdate(Block with { MinimapIcon = value });

    private void DispatchUpdate(FilterBlock block) => Dispatcher.Dispatch(new FilterFeatureReducers.SetBlockAction(GroupId, block));

    private static string GetColorName(FilterColor? color) => color?.Name ?? "[Default]";
}