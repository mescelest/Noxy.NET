@inject IDispatcher Dispatcher
@inject IStateSelection<FilterFeatureState, FilterBlock?> BlockSelection
@inject IStateSelection<FilterFeatureState, Dictionary<ColorTypeEnum, List<FilterColor>>> ColorCollectionSelection
@inherits FluxorElementComponent

<div @attributes="AdditionalAttributes" class="@CssClass">

    @if (Block != null)
    {
        <FormField Label="Text Color" For="@TextColorId">
            <InputControlSelect TOption="FilterColor" ID="@TextColorId" Name="@TextColorId" OptionList="TextFilterColorSet"
                                @bind-Value:get="Block.TextColor" @bind-Value:set="SetTextColor">
                @GetColorName(context)
            </InputControlSelect>
        </FormField>

        <FormField Label="Background Color" For="@BackgroundColorId">
            <InputControlSelect TOption="FilterColor" ID="@BackgroundColorId" Name="@BackgroundColorId" OptionList="BackgroundFilterColorSet"
                                @bind-Value:get="Block.BackgroundColor" @bind-Value:set="SetBackgroundColor">
                @GetColorName(context)
            </InputControlSelect>
        </FormField>

        <FormField Label="Border Color" For="@BorderId">
            <InputControlSelect TOption="FilterColor" ID="@BorderId" Name="@BorderId" OptionList="BorderFilterColorSet"
                                @bind-Value:get="Block.BorderColor" @bind-Value:set="SetBorderColor">
                @GetColorName(context)
            </InputControlSelect>
        </FormField>

        <FormField Label="@($"Font Size ({FontSize})")" For="@FontSizeId">
            <InputElementRange class="poe-range-slider" ID="@FontSizeId" Min="18" Max="45" Value="@((double)FontSize)" OnChange="OnFontSizeChange"/>
        </FormField>
    }

</div>

@code {

    [Parameter, EditorRequired]
    public Guid GroupId { get; set; }

    [Parameter, EditorRequired]
    public Guid BlockId { get; set; }

    private FilterBlock? Block => BlockSelection.Value;
    private int FontSize => Block?.FontSize ?? 32;

    // Unique IDs combined with GroupId and BlockId to ensure total context safety
    private string TextColorId => $"text-color-{GroupId}-{BlockId}";
    private string BackgroundColorId => $"background-color-{GroupId}-{BlockId}";
    private string BorderId => $"border-color-{GroupId}-{BlockId}";
    private string FontSizeId => $"font-size-slider-{GroupId}-{BlockId}";

    private HashSet<FilterColor?> TextFilterColorSet => GetColorsForType(ColorTypeEnum.Text);
    private HashSet<FilterColor?> BackgroundFilterColorSet => GetColorsForType(ColorTypeEnum.Background);
    private HashSet<FilterColor?> BorderFilterColorSet => GetColorsForType(ColorTypeEnum.Border);

    protected override void OnInitialized()
    {
        base.OnInitialized();

        BlockSelection.Select(state => state.Filter.GroupList.FirstOrDefault(g => g.ID == GroupId)?.BlockList.FirstOrDefault(b => b.ID == BlockId));
        ColorCollectionSelection.Select(state => state.Filter.CustomColorCollection);
    }

    private HashSet<FilterColor?> GetColorsForType(ColorTypeEnum type)
    {
        Dictionary<ColorTypeEnum, List<FilterColor>>? collection = ColorCollectionSelection.Value;
        if (collection == null || !collection.TryGetValue(type, out List<FilterColor>? list))
        {
            return [null];
        }

        return [null, .. list];
    }

    private void SetTextColor(FilterColor? value) => UpdateBlockColor(ColorTypeEnum.Text, value);
    private void SetBackgroundColor(FilterColor? value) => UpdateBlockColor(ColorTypeEnum.Background, value);
    private void SetBorderColor(FilterColor? value) => UpdateBlockColor(ColorTypeEnum.Border, value);

    private void UpdateBlockColor(ColorTypeEnum type, FilterColor? color)
    {
        if (Block == null) return;

        FilterBlock updatedBlock = Block.Clone();
        switch (type)
        {
            case ColorTypeEnum.Text: updatedBlock.TextColor = color; break;
            case ColorTypeEnum.Background: updatedBlock.BackgroundColor = color; break;
            case ColorTypeEnum.Border: updatedBlock.BorderColor = color; break;
            default: throw new ArgumentOutOfRangeException(nameof(type), type, null);
        }

        DispatchUpdate(updatedBlock);
    }

    private void OnFontSizeChange(ChangeEventArgs e)
    {
        if (Block == null) return;

        FilterBlock updatedBlock = Block.Clone();
        updatedBlock.FontSize = double.TryParse(e.Value?.ToString(), out double size) ? (int)size : 32;
        DispatchUpdate(updatedBlock);
    }

    private void DispatchUpdate(FilterBlock updatedBlock)
    {
        Dispatcher.Dispatch(new FilterFeatureReducers.EditBlockAction(GroupId, updatedBlock));
    }

    private static string GetColorName(FilterColor? color) => color?.Name ?? "-- Default --";
}