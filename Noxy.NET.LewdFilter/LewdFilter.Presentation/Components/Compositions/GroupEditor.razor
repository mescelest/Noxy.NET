@inject IDispatcher Dispatcher
@inject IStateSelection<FilterFeatureState, ImmutableArray<FilterGroup>> GroupListSelection
@inherits FluxorElementComponent

<nav class="GroupEditor">
    <SortableTable class="table" List="GroupList" OnUpdate="OnSortableTableUpdate" KeySelector="(g, _) => g.ID" Handle="sortable-handle">
        <TableHeader>
            <div role="cell"></div>
            <div role="cell">
                <strong>Name</strong>
            </div>
            <div role="cell"></div>
            <div role="cell"></div>
            <div role="cell"></div>
        </TableHeader>
        <TableRow>
            <div class="table-cell sortable-handle" role="cell">
                <MaterialIcon Icon="drag_handle" Size="20px"/>
            </div>

            <div class="table-cell" role="cell">
                <InputControlText class="name" Size="20" @bind-Value:get="@context.Row.Name" @bind-Value:set="e => OnInputGroupEditNameChange(e, context.Row)"/>
            </div>

            <div class="table-cell" role="cell">
                @if (context.Index == 0)
                {
                    <Button @key='"add-btn"' type="button" Status="StatusEnum.Success" IsIcon="true" title="Add group" @onclick="OnButtonAddGroupClick">
                        <MaterialIcon Icon="add" Size="20px"/>
                    </Button>
                }
                else
                {
                    <Button @key='"remove-btn"' type="button" Status="StatusEnum.Error" IsIcon="true" title="Delete group" @onclick="() => OnButtonDeleteGroupClick(context.Row.ID)">
                        <MaterialIcon Icon="remove" Size="20px"/>
                    </Button>
                }
            </div>

            <div class="table-cell" role="cell">
                <Button type="button" Status="StatusEnum.Notice" IsIcon="true" @onclick="() => OnButtonCloneGroupClick(context.Row.ID)" title="Clone group">
                    <MaterialIcon Icon="content_copy" Size="20px"/>
                </Button>
            </div>

            <div class="table-cell" role="cell">
                <Button type="button" Status="StatusEnum.None" IsIcon="true" @onclick="() => OnButtonExportGroupClick(context.Row.ID)" title="Export group">
                    <MaterialIcon Icon="download" Size="20px"/>
                </Button>
            </div>

            <div class="table-cell" role="cell">
                <a href="#@context.Row.ToGroupID()" class="navigate" title="Scroll to group">
                    <Button type="button" Status="StatusEnum.Info" IsIcon="true">
                        <MaterialIcon Icon="jump_to_element" Size="20px"/>
                    </Button>
                </a>
            </div>
        </TableRow>
    </SortableTable>
</nav>

@code {

    private List<FilterGroup> GroupList => [.. GroupListSelection.Value];

    protected override void OnInitialized()
    {
        base.OnInitialized();

        GroupListSelection.Select(FilterFeatureState.SelectGroupList());
    }

    private void OnSortableTableUpdate((int IndexOld, int IndexNew) indices)
    {
        FilterGroup targetGroup = GroupList[indices.IndexOld];
        Dispatcher.Dispatch(new FilterFeatureReducers.MoveGroupToIndexAction(targetGroup.ID, indices.IndexNew));
    }

    private void OnInputGroupEditNameChange(string? value, FilterGroup group)
    {
        Dispatcher.Dispatch(new FilterFeatureReducers.SetGroupAction(group with { Name = value ?? string.Empty }));
    }

    private void OnButtonAddGroupClick()
    {
        Dispatcher.Dispatch(new FilterFeatureReducers.SetGroupAction(FilterGroup.Default));
    }

    private void OnButtonDeleteGroupClick(Guid id) => Dispatcher.Dispatch(new FilterFeatureReducers.RemoveGroupAction(id));

    private void OnButtonExportGroupClick(Guid id) => Dispatcher.Dispatch(new FilterFeatureReducers.ExportGroupAction(id));

    private void OnButtonCloneGroupClick(Guid id) => Dispatcher.Dispatch(new FilterFeatureReducers.CloneGroupAction(id));

}