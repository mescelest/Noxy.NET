@inject IDispatcher Dispatcher
@inject IStateSelection<FilterFeatureState, FilterBlock> BlockSelection
@inherits FluxorElementComponent

<div @attributes="AdditionalAttributes" class="@CssClass">
    <div class="header">
        <div class="action-list">
            <FormField Label="Filter by name" For="@FilterByNameId">
                <InputControlText ID="@FilterByNameId" Size="24" OnInputDelay="200" @bind-Value:get="@_inputSearch" @bind-Value:set="OnInputSearchChange"/>
            </FormField>

            <Button type="button" Status="StatusEnum.Error" @onclick="OnResetBaseTypes" disabled="@(!CurrentBaseTypeList.Any())">
                Reset All Selections
            </Button>
        </div>
    </div>

    <div class="content">
        @if (_collectionGroupFiltered.Count > 0)
        {
            @foreach (KeyValuePair<string, List<string>> group in _collectionGroupFiltered)
            {
                <BaseTypeGroup @key="group.Key" GroupKey="@group.Key" GroupItems="@group.Value" CurrentBaseTypeList="@CurrentBaseTypeList" GroupID="@GroupID" BlockID="@BlockID" IsGroupSelected="@GetSelectAll(group.Key)"/>
            }
        }
        else
        {
            <p class="no-results">No base types match your search.</p>
        }
    </div>
</div>

@code {

    [Parameter, EditorRequired]
    public Guid GroupID { get; set; }

    [Parameter, EditorRequired]
    public Guid BlockID { get; set; }

    private string? _inputSearch;
    private Dictionary<string, List<string>> _collectionGroupFiltered = [];

    private FilterBlock Block => BlockSelection.Value;
    private HashSet<string> CurrentBaseTypeList => Block.BaseTypeList;

    private string FilterByNameId => $"filter-{BlockID}";

    protected override void OnInitialized()
    {
        base.OnInitialized();

        BlockSelection.Select(FilterFeatureState.SelectBlock(GroupID, BlockID));
        UpdateFilteredGroupCollection();
    }

    private void OnInputSearchChange(string? value)
    {
        if (_inputSearch == value) return;

        _inputSearch = value;
        UpdateFilteredGroupCollection();
    }

    private void UpdateFilteredGroupCollection()
    {
        Dictionary<string, List<string>> result = new();

        foreach (KeyValuePair<string, IReadOnlyList<string>> pair in BaseTypeConstants.BaseTypes)
        {
            IEnumerable<string> filtered = !string.IsNullOrWhiteSpace(_inputSearch)
                ? pair.Value.Where(v => v.Contains(_inputSearch, StringComparison.OrdinalIgnoreCase))
                : pair.Value;

            List<string> list = filtered.ToList();
            if (list.Count > 0)
            {
                result[pair.Key] = list;
            }
        }

        _collectionGroupFiltered = result;
    }

    private bool? GetSelectAll(string key)
    {
        if (!_collectionGroupFiltered.TryGetValue(key, out List<string>? filteredList) || filteredList.Count == 0)
        {
            return false;
        }

        return filteredList.All(x => CurrentBaseTypeList.Contains(x));
    }


    private void OnResetBaseTypes()
    {
        OnInputSearchChange(string.Empty);

        if (CurrentBaseTypeList.Count > 0)
        {
            DispatchUpdateWithNewBaseList([]);
        }
    }

    private void DispatchUpdateWithNewBaseList(HashSet<string> list)
    {
        Dispatcher.Dispatch(new FilterFeatureReducers.SetBlockAction(GroupID, Block with { BaseTypeList = list }));
    }

}