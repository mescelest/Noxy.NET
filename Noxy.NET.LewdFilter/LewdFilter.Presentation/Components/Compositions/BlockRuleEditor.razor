@inject IDispatcher Dispatcher
@inject IStateSelection<FilterFeatureState, FilterBlock> BlockSelection
@inherits FluxorElementComponent

<div @attributes="AdditionalAttributes" class="@CssClass" role="table">
    <div class="header" role="rowheader">
        <div class="handle" role="cell"></div>
        <div class="action" role="cell"></div>
        <div class="keyword" role="cell">Keyword</div>
        <div class="control" role="cell">Configuration</div>
    </div>

    <div class="row">
        <div class="handle">
            <MaterialIcon Icon="drag_handle" Size="20px"/>
        </div>

        <div class="action">
            <Button type="button" Status="StatusEnum.Success" IsIcon="true" @onclick="OnButtonRuleAddClick">
                <MaterialIcon Icon="add" Size="20px"/>
            </Button>
        </div>

        <div class="keyword">
            Block Visibility
        </div>

        <div class="control">
            <InputControlCheckbox class="visibility" Option="true" @bind-Value:get="Block.IsShow" @bind-Value:set="OnCheckboxShowChange">
                <span class="label">@VisibilityText</span>
            </InputControlCheckbox>
        </div>
    </div>

    <SortableList class="list" List="EditableRuleList" KeySelector="GetRowKey" HandleClass="sortable-handle" DragClass="row" OnUpdate="OnSortableListUpdate">
        <div @key="context.Item.ID" class="row">

            <div class="sortable-handle">
                <MaterialIcon Icon="drag_handle" Size="20px"/>
            </div>

            <div class="action">
                <Button type="button" Status="StatusEnum.Error" IsIcon="true" @onclick="() => OnButtonRuleRemoveClick(context.Item.ID)">
                    <MaterialIcon Icon="remove" Size="20px"/>
                </Button>
            </div>

            <div class="keyword">
                <InputControlSelect TOption="FilterKeywordEnum" OptionList="_availableKeywords" @bind-Value:get="context.Item.Keyword" @bind-Value:set="v => OnSelectRuleKeywordChange(context.Item.ID, v)">
                    <ChildContent Context="keyword">
                        @keyword.ToTextString()
                    </ChildContent>
                </InputControlSelect>
            </div>

            <div class="control">
                <RuleComponentDispatcher GroupID="GroupID" BlockID="BlockID" Rule="context.Item"/>
            </div>
        </div>
    </SortableList>
</div>

@code {

    [Parameter, EditorRequired]
    public Guid GroupID { get; set; }

    [Parameter, EditorRequired]
    public Guid BlockID { get; set; }

    private readonly HashSet<FilterKeywordEnum> _availableKeywords = Enum.GetValues<FilterKeywordEnum>().ToHashSet();

    private string VisibilityText => Block.IsShow ? "Show" : "Hide";
    private FilterBlock Block => BlockSelection.Value;

    private IReadOnlyList<FilterRule> EditableRuleList => Block.RuleList;

    private static object GetRowKey(FilterRule rule, int index) => rule.ID;

    protected override void OnInitialized()
    {
        base.OnInitialized();

        BlockSelection.Select(FilterFeatureState.SelectBlock(GroupID, BlockID));
    }

    private void OnCheckboxShowChange(bool value)
    {
        Dispatcher.Dispatch(new FilterFeatureReducers.SetBlockAction(GroupID, Block with { IsShow = value }));
    }

    private void OnButtonRuleAddClick()
    {
        Dispatcher.Dispatch(new FilterFeatureReducers.SetRuleAction(GroupID, BlockID, FilterRule.Default));
    }

    private void OnSelectRuleKeywordChange(Guid ruleId, FilterKeywordEnum keyword)
    {
        FilterRule rule = FilterRule.FromKeyword(keyword) with { ID = ruleId };
        Dispatcher.Dispatch(new FilterFeatureReducers.SetRuleAction(GroupID, BlockID, rule));
    }

    private void OnButtonRuleRemoveClick(Guid ruleId)
    {
        Dispatcher.Dispatch(new FilterFeatureReducers.RemoveRuleAction(GroupID, BlockID, ruleId));
    }

    private void OnSortableListUpdate((int IndexOld, int IndexNew) indices)
    {
        FilterRule ruleToMove = EditableRuleList[indices.IndexOld];
        Dispatcher.Dispatch(new FilterFeatureReducers.MoveRuleAction(GroupID, BlockID, ruleToMove.ID, indices.IndexNew));
    }

}