@inject IDispatcher Dispatcher
@inject IStateSelection<FilterFeatureState, FilterBlock?> BlockSelection
@inherits FluxorElementComponent

<div @attributes="AdditionalAttributes" class="@CssClass">

    @if (Block != null)
    {
        <FormField Label="Rarity" For="@RarityId">
            <FilterRarityCondition id="@RarityId" Value="Block.Rarity" ValueChanged="OnRarityChange"/>
        </FormField>

        <FormField Label="Stack Size" For="@StackSizeId">
            <FilterIntCondition id="@StackSizeId" Value="Block.StackSize" ValueChanged="OnStackSizeChange"/>
        </FormField>

        <FormField Label="Quality" For="@QualityId">
            <FilterIntCondition id="@QualityId" Value="Block.Quality" ValueChanged="OnQualityChange"/>
        </FormField>

        <FormField Label="Unidentified Item Tier" For="@UnidentifiedTierId">
            <FilterIntCondition id="@UnidentifiedTierId" Value="Block.UnidentifiedItemTier" ValueChanged="OnUnidentifiedTierChange"/>
        </FormField>
    }

</div>

@code {

    [Parameter, EditorRequired]
    public Guid GroupId { get; set; }

    [Parameter, EditorRequired]
    public Guid BlockId { get; set; }

    private FilterBlock? Block => BlockSelection.Value;
    private string RarityId => $"rarity-condition-{GroupId}";
    private string StackSizeId => $"stack-size-condition-{GroupId}";
    private string QualityId => $"quality-condition-{GroupId}";
    private string UnidentifiedTierId => $"unidentified-tier-condition-{GroupId}";

    protected override void OnInitialized()
    {
        base.OnInitialized();

        BlockSelection.Select(state => state.Filter.GroupList.FirstOrDefault(g => g.ID == GroupId)?.BlockList.FirstOrDefault(b => b.ID == BlockId));
    }

    private void OnRarityChange(FilterComparatorRarity? condition) => UpdateBlockCondition(b => b with { Rarity = condition });
    private void OnStackSizeChange(FilterComparatorInt? condition) => UpdateBlockCondition(b => b with { StackSize = condition });
    private void OnQualityChange(FilterComparatorInt? condition) => UpdateBlockCondition(b => b with { Quality = condition });
    private void OnUnidentifiedTierChange(FilterComparatorInt? condition) => UpdateBlockCondition(b => b with { UnidentifiedItemTier = condition });

    private void UpdateBlockCondition(Func<FilterBlock, FilterBlock> mutateBlock)
    {
        if (Block == null) return;

        FilterBlock updatedBlock = mutateBlock(Block);

        Dispatcher.Dispatch(new FilterFeatureReducers.EditBlockAction(GroupId, updatedBlock));
    }

}