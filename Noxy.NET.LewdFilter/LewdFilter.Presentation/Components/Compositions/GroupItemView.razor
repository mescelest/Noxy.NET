@inject IStateSelection<FilterFeatureState, string> GroupNameSelection
@inject IDispatcher Dispatcher
@inherits FluxorElementComponent

<div @attributes="AdditionalAttributes" class="@CssClass">
    <Collapsible class="group" id="@($"group-{GroupId}")" @bind-Collapsed="IsCollapsed">
        <Header>
            <div class="header">
                <h3>@GroupName</h3>
                <Button type="button" class="btn-create-block" Status="StatusEnum.Success" IsIcon="true" @onclick="OnCreateBlock">
                    <MaterialIcon Icon="add" Size="20px"/>
                </Button>
            </div>
        </Header>
        <Content>
            <BlockListView GroupId="GroupId"/>
        </Content>
    </Collapsible>
</div>

@code {

    [Parameter, EditorRequired]
    public Guid GroupId { get; set; }

    private bool IsCollapsed { get; set; }

    private string GroupName => GroupNameSelection.Value ?? "Unnamed Group";

    protected override void OnInitialized()
    {
        base.OnInitialized();

        GroupNameSelection.Select(FilterFeatureState.SelectGroupName(GroupId));
    }

    private void OnCreateBlock()
    {
        Dispatcher.Dispatch(new FilterFeatureReducers.SetBlockAction(GroupId, FilterBlock.Default));
    }

}