@inject IDispatcher Dispatcher
@inject IState<FilterFeatureState> State
@inherits FluxorElementComponent

<header @attributes="AdditionalAttributes" class="@CssClass" role="banner">
    <div class="header-brand">
        <span class="brand-icon">⚙️</span>
        <h1>@State.Value.Filter.Name</h1>
    </div>

    <div class="header-actions">

        <label class="btn-header btn-secondary @(State.Value.IsLoading ? "is-disabled" : "")" style="cursor: pointer;">
            Import Group
            <InputFile OnChange="OnFileImportGroupChange" disabled="@State.Value.IsLoading" style="display: none;" accept=".json"/>
        </label>

        <label class="btn-header btn-secondary @(State.Value.IsLoading ? "is-disabled" : "")" style="cursor: pointer;">
            Import JSON
            <InputFile OnChange="OnFileImportFilterChange" disabled="@State.Value.IsLoading" style="display: none;" accept=".json"/>
        </label>

        <Button type="button" class="btn-header btn-secondary" disabled="@State.Value.IsLoading" @onclick="OnButtonExportClick">
            Export JSON
        </Button>

        <Button type="button" class="btn-header btn-primary" disabled="@State.Value.IsLoading" @onclick="OnButtonCompileClick">
            Compile & Download
        </Button>
    </div>
</header>

@code {

    private void OnButtonExportClick() => Dispatcher.Dispatch(new FilterFeatureReducers.ExportFilterAction());
    private void OnButtonCompileClick() => Dispatcher.Dispatch(new FilterFeatureReducers.SaveFilterAction());

    private async Task OnFileImportFilterChange(InputFileChangeEventArgs e)
    {
        string fileContent;

        try
        {
            await using Stream stream = e.File.OpenReadStream(maxAllowedSize: 1024 * 1024 * 10);
            using StreamReader reader = new(stream);
            fileContent = await reader.ReadToEndAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"UI File Reader failed to read uploaded asset: {ex.Message}");
            return;
        }

        if (!string.IsNullOrWhiteSpace(fileContent))
        {
            Dispatcher.Dispatch(new FilterFeatureReducers.ImportFilterAction(fileContent));
        }
    }

    private async Task OnFileImportGroupChange(InputFileChangeEventArgs e)
    {
        string fileContent;

        try
        {
            await using Stream stream = e.File.OpenReadStream(maxAllowedSize: 1024 * 1024 * 10);
            using StreamReader reader = new(stream);
            fileContent = await reader.ReadToEndAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"UI File Reader failed to read uploaded group asset: {ex.Message}");
            return;
        }

        if (!string.IsNullOrWhiteSpace(fileContent))
        {
            Dispatcher.Dispatch(new FilterFeatureReducers.ImportGroupAction(fileContent));
        }
    }

}