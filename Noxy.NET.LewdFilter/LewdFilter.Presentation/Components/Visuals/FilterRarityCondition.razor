@inherits BaseInput<FilterComparatorRarity>

<div @attributes="AdditionalAttributes" class="@CssClass">
    <InputControlSelect TOption="FilterComparatorTypeEnum" OptionList="_operators" Name="operator" @bind-Value:get="_operator" @bind-Value:set="OnSelectOperatorChange">
        @context.ToTextString()
    </InputControlSelect>

    <InputControlSelect TOption="FilterRarityTypeEnum" OptionList="_setRarityTypeEnum" ID="@ID" Name="value" @bind-Value:get="_rarityValue" @bind-Value:set="OnSelectValueChange">
        @context.ToTextString()
    </InputControlSelect>
</div>

@code {
    private readonly HashSet<FilterComparatorTypeEnum> _operators = Enum.GetValues<FilterComparatorTypeEnum>().ToHashSet();
    private readonly HashSet<FilterRarityTypeEnum> _setRarityTypeEnum = Enum.GetValues<FilterRarityTypeEnum>().ToHashSet();

    private FilterRarityTypeEnum _rarityValue;
    private FilterComparatorTypeEnum _operator = FilterComparatorTypeEnum.Equal;

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        _rarityValue = Value?.Value ?? FilterRarityTypeEnum.Normal;
        _operator = Value?.FilterComparatorType ?? FilterComparatorTypeEnum.Equal;
    }

    private void OnSelectValueChange(FilterRarityTypeEnum value)
    {
        _rarityValue = value;
        PushUpdate();
    }

    private void OnSelectOperatorChange(FilterComparatorTypeEnum op)
    {
        _operator = op;
        PushUpdate();
    }

    private void PushUpdate()
    {
        FilterComparatorRarity result = new() { Value = _rarityValue, FilterComparatorType = _operator };
        NotifyChange(result);
    }

}