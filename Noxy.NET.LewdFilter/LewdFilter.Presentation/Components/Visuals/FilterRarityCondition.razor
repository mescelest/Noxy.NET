@inherits BaseInput<FilterComparatorRarity?>

<div @attributes="AdditionalAttributes" class="@CssClass">
    @if (_operator == FilterComparatorTypeEnum.Between)
    {
        <InputControlSelect TOption="FilterRarityTypeEnum?" OptionList="_setRarityTypeEnum" Name="left" @bind-Value="_left" @bind-Value:after="PushUpdate">
            @context?.ToFilterString()
        </InputControlSelect>
    }

    <InputControlSelect TOption="FilterComparatorTypeEnum" OptionList="_operators" Name="operator" @bind-Value:get="_operator" @bind-Value:set="SetOperator">
        @context.ToTextSymbol()
    </InputControlSelect>

    <InputControlSelect TOption="FilterRarityTypeEnum?" OptionList="_setRarityTypeEnum" Name="right" @bind-Value="_right" @bind-Value:after="PushUpdate">
        @context?.ToFilterString()
    </InputControlSelect>
</div>

@code {

    private readonly HashSet<FilterComparatorTypeEnum> _operators = Enum.GetValues<FilterComparatorTypeEnum>().ToHashSet();
    private HashSet<FilterRarityTypeEnum?> _setRarityTypeEnum = [];

    private FilterRarityTypeEnum? _left;
    private FilterRarityTypeEnum? _right;
    private FilterComparatorTypeEnum _operator = FilterComparatorTypeEnum.Equal;
    
    protected override void OnInitialized()
    {
        _setRarityTypeEnum = [null, .. Enum.GetValues<FilterRarityTypeEnum>().Cast<FilterRarityTypeEnum?>()];
    }

    protected override void OnParametersSet()
    {
        _left = Value?.Left;
        _right = Value?.Right;
        _operator = Value?.FilterComparatorType ?? FilterComparatorTypeEnum.Equal;
    }

    private void SetOperator(FilterComparatorTypeEnum op)
    {
        _operator = op;
        if (_operator != FilterComparatorTypeEnum.Between) _right = null;
        PushUpdate();
    }

    private void PushUpdate()
    {
        if (_left is null && _right is null)
        {
            ValueChanged.InvokeAsync(null);
        }
        else
        {
            ValueChanged.InvokeAsync(new() { Left = _left, Right = _right, FilterComparatorType = _operator });
        }
    }
}
