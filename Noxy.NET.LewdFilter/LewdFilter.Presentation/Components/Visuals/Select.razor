@typeparam TOption where TOption : notnull

<div class="select">
    <select class="control" id="@ID" name="@Name" disabled="@IsDisabled" value="@CurrentSelectedIndex" @onchange="OnSelectionChanged">
        @for (int i = 0; i < _cacheList.Length; i++)
        {
            <option value="@i">
                @ChildContent(_cacheList[i])
            </option>
        }
    </select>

    <MaterialIcon Icon="expand_more" Size="16px"/>
</div>

@code {

    [Parameter]
    public string? ID { get; set; }

    [Parameter]
    public string? Name { get; set; }

    [Parameter]
    public bool IsDisabled { get; set; }

    [Parameter]
    public TOption? Value { get; set; }

    [Parameter]
    public EventCallback<TOption> ValueChanged { get; set; }

    [Parameter, EditorRequired]
    public HashSet<TOption> List { get; set; }

    [Parameter, EditorRequired]
    public RenderFragment<TOption> ChildContent { get; set; }

    private TOption[] _cacheList = [];
    private HashSet<TOption>? _cacheSet;

    private string CurrentSelectedIndex => Array.FindIndex(_cacheList, item => EqualityComparer<TOption>.Default.Equals(item, Value)).ToString();

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        if (List == _cacheSet && _cacheList.Length == List.Count) return;
        _cacheSet = List;
        _cacheList = List.ToArray();
    }

    private async Task OnSelectionChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int index))
        {
            await ValueChanged.InvokeAsync(_cacheList[index]);
        }
        else
        {
            await ValueChanged.InvokeAsync(default);
        }
    }

}