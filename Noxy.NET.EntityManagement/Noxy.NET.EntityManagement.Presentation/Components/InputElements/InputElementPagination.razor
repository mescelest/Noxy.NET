@inherits BaseInput<int?>

<Pagination @attributes="AdditionalAttributes" class="@CssClass" PageSize="PageSize" Count="Count" Disabled="@Disabled" Value="Value" ValueChanged="ValueChanged" ValueExpression="@ValueExpression">
    <Next>
        <MaterialIcon class="pagination-icon" Icon="chevron_right" Size="24px"/>
    </Next>
    <First>
        <MaterialIcon class="pagination-icon" Icon="first_page" Size="24px"/>
    </First>
    <Previous>
        <MaterialIcon class="pagination-icon" Icon="chevron_left" Size="24px"/>
    </Previous>
    <Last>
        <MaterialIcon class="pagination-icon" Icon="last_page" Size="24px"/>
    </Last>
</Pagination>

@code {

    [Parameter, EditorRequired]
    public int PageSize { get; set; }

    [Parameter, EditorRequired]
    public int Count { get; set; }

    [Parameter]
    public bool? Disabled { get; set; }

}