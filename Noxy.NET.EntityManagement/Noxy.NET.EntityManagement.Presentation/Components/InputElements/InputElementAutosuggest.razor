@typeparam TOption
@inherits BaseInput<TOption>
@inject IJSRuntime JS

<div @ref="_refComponent" class="@CssClass" @onclick="DropdownOpenClickHandler">
    <input @ref="_refInput" id="@IDCurrent" class="input" autocomplete="off" name="@GetName()" size="@SizeCurrent" value="@TextCurrent"/>

    @if (_isDropdownOpen)
    {
        <div class="dropdown" @onmouseleave="() => SetIndexPreview(-1)">
            @if (LoadingCurrent)
            {
                <div class="loading">Loading...</div>
            }
            else if (IsSearchingBelowMinLength && !string.IsNullOrWhiteSpace(MinLengthText))
            {
                <div class="min-length">@MinLengthText</div>
            }
            else if (_cacheOptionList.Count > 0)
            {
                @for (int i = 0; i < _cacheOptionList.Count; i++)
                {
                    int index = i;
                    OptionDisplay item = _cacheOptionList[index];
                    bool selected = index == IndexSelected;

                    <span class="option" data-selected="@selected" @onmousedown="() => Select(index)" @onmouseenter="() => SetIndexPreview(index)">
                        @item.Text
                    </span>
                }
            }
            else if (!IsSearchingBelowMinLength && !string.IsNullOrWhiteSpace(NoResultText))
            {
                <div class="no-result">@NoResultText</div>
            }
        </div>
    }
</div>

@code {

    private readonly record struct OptionDisplay(TOption Option, string Text);

    private ElementReference _refComponent;
    private ElementReference _refInput;
    private IJSObjectReference? _autosuggestModule;
    private DotNetObjectReference<InputElementAutosuggest<TOption>>? _refDotNet;

    private TOption? _cacheValue;
    private List<OptionDisplay> _cacheOptionList = [];
    private HashSet<TOption> _cacheOptionSet = [];

    private string? _textValue;
    private string? _textSearch;
    private string? _textPreview;
    private bool _isDropdownOpen;
    private int _indexPreview = -1;
    private int _indexCurrent = -1;

    [Parameter, EditorRequired]
    public required HashSet<TOption> OptionSet { get; set; }

    [Parameter]
    public int? MinLength { get; set; }
    private int MinLengthCurrent => MinLength ?? 2;

    [Parameter]
    public bool? Loading { get; set; }
    private bool LoadingCurrent => Loading ?? false;

    [Parameter]
    public int? DebounceDelay { get; set; }
    private int DebounceDelayCurrent => DebounceDelay ?? 500;

    [Parameter]
    public int? Size { get; set; }
    private int SizeCurrent => Size ?? 40;

    [Parameter, EditorRequired]
    public required EventCallback<string> OnSearch { get; set; }

    [Parameter]
    public Func<TOption?, string>? DisplaySelector { get; set; }

    [Parameter]
    public string? MinLengthText { get; set; }

    [Parameter]
    public string? NoResultText { get; set; }

    private string TextCurrent => _textPreview ?? _textSearch ?? _textValue ?? string.Empty;
    private int IndexSelected => _indexPreview >= 0 ? _indexPreview : _indexCurrent;
    private bool HasMinLength => _textSearch?.Length >= MinLengthCurrent;
    private bool IsSearchingBelowMinLength => _textSearch is not null && !HasMinLength;
    private bool IsIndexValid => IndexSelected >= 0 && IndexSelected < _cacheOptionList.Count;
    private bool HasDropdownContent => LoadingCurrent || (IsSearchingBelowMinLength && !string.IsNullOrWhiteSpace(MinLengthText)) || _cacheOptionList.Count > 0;

    protected override async Task OnAfterFirstRenderAsync()
    {
        _refDotNet = DotNetObjectReference.Create(this);
        _autosuggestModule = await JS.InvokeAsync<IJSObjectReference>("import", "./_content/Noxy.NET.EntityManagement.Presentation/Components/InputElements/InputElementAutosuggest.razor.js");
        string[] listCallback = [nameof(OnArrowDown), nameof(OnArrowUp), nameof(OnEnterKey), nameof(OnEscapeKey), nameof(OnTabKey), nameof(OnBlur), nameof(OnValueInput)];
        await _autosuggestModule.InvokeVoidAsync("RegisterAutosuggest", DebounceDelayCurrent, _refComponent, _refInput, _refDotNet, listCallback);
    }

    protected override void OnParametersSet()
    {
        bool shouldUpdateIndex = false;

        if (!_cacheOptionSet.SetEquals(OptionSet))
        {
            _cacheOptionSet = new(OptionSet);
            _cacheOptionList = OptionSet
                .Select(x => new OptionDisplay(x, GetDisplayText(x)))
                .OrderBy(x => x.Text, StringComparer.CurrentCultureIgnoreCase)
                .ToList();

            _indexPreview = -1;
            shouldUpdateIndex = true;
        }

        if (!EqualityComparer<TOption>.Default.Equals(Value, _cacheValue))
        {
            _cacheValue = Value;
            _textValue = GetDisplayText(Value);
            _textPreview = null;
            _textSearch = null;
            _indexPreview = -1;
            shouldUpdateIndex = true;
        }

        if (shouldUpdateIndex)
        {
            UpdateIndexCurrent();
        }
    }

    [JSInvokable]
    public async Task OnValueInput(string value)
    {
        _textSearch = value;
        _textPreview = null;
        _indexPreview = -1;

        if (MinLengthCurrent > _textSearch.Length)
        {
            _isDropdownOpen = true;
            _indexCurrent = -1;
        }
        else
        {
            UpdateIndexCurrent();
            _isDropdownOpen = true;
            await OnSearch.InvokeAsync(_textSearch);
        }

        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task OnArrowDown()
    {
        _isDropdownOpen = HasDropdownContent;

        if (!IsSearchingBelowMinLength && _cacheOptionList.Count > 0)
        {
            SetIndexPreview(IndexSelected >= _cacheOptionList.Count - 1 ? -1 : IndexSelected + 1);
        }

        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task OnArrowUp()
    {
        _isDropdownOpen = HasDropdownContent;

        if (!IsSearchingBelowMinLength && _cacheOptionList.Count > 0)
        {
            SetIndexPreview(IndexSelected < 0 ? _cacheOptionList.Count - 1 : IndexSelected - 1);
        }

        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task OnEnterKey()
    {
        if (_isDropdownOpen)
        {
            Commit(!IsSearchingBelowMinLength && IsIndexValid ? _cacheOptionList[IndexSelected].Option : default);
            _isDropdownOpen = false;
        }
        else
        {
            _isDropdownOpen = HasDropdownContent;
        }

        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task OnEscapeKey()
    {
        ResetSearchState();
        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task OnTabKey()
    {
        if (!IsSearchingBelowMinLength && IsIndexValid)
        {
            _isDropdownOpen = false;
            Commit(_cacheOptionList[IndexSelected].Option);
        }
        else
        {
            ResetSearchState();
        }

        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task OnBlur()
    {
        ResetSearchState();
        await InvokeAsync(StateHasChanged);
    }

    private void DropdownOpenClickHandler()
    {
        _isDropdownOpen = HasDropdownContent;
    }

    private string GetDisplayText(TOption? item)
    {
        return DisplaySelector?.Invoke(item) ?? item?.ToString() ?? string.Empty;
    }

    private void UpdateIndexCurrent()
    {
        string text = _textSearch ?? _textValue ?? string.Empty;
        _indexCurrent = _cacheOptionList.FindIndex(item => StringComparer.CurrentCultureIgnoreCase.Equals(item.Text, text));
    }

    private void SetIndexPreview(int index)
    {
        int nextIndex = Math.Clamp(index, -1, _cacheOptionList.Count - 1);

        if (_indexPreview == nextIndex)
        {
            return;
        }

        _indexPreview = nextIndex;
        _textPreview = _indexPreview >= 0 ? _cacheOptionList[_indexPreview].Text : null;
    }

    private void Commit(TOption? item)
    {
        NotifyChange(item);
    }

    private void Select(int index)
    {
        _isDropdownOpen = false;
        Commit(_cacheOptionList[index].Option);
    }

    private void ResetSearchState()
    {
        _textSearch = null;
        _textPreview = null;
        _indexPreview = -1;
        UpdateIndexCurrent();
        _isDropdownOpen = false;
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_autosuggestModule != null)
            {
                await _autosuggestModule.InvokeVoidAsync("DeregisterAutosuggest", _refInput);
                await _autosuggestModule.DisposeAsync();
            }
        }
        catch (JSDisconnectedException)
        {
            // Ignore
        }

        _refDotNet?.Dispose();
    }

}
