@inject IState<FeatureSchemaContextState> StateSchemaContext
@inject IDispatcher Dispatcher
@inject TextService TextService
@inherits FluxorElementComponent

<div @attributes="AdditionalAttributes" class="@CssClass">
    <div class="header">
        <div class="title">
            <DynamicHTMLTag Tag="@HeaderLevelCurrent.ToText()">@SchemaContext.Name</DynamicHTMLTag>
            <NavLink href="@Link">
                <MaterialIcon Icon="arrow_right_alt" Size="@Size"/>
            </NavLink>
        </div>

        <ButtonList Alignment="ButtonListAlignmentEnum.Right">
            @if (Schema.TimeActivated == null)
            {
                <Button Status="StatusEnum.Error" @onclick="OnButtonDeleteClick">Delete</Button>
                <Button Status="StatusEnum.Info" @onclick="OnButtonCloneClick">Clone</Button>
                <Button Status="StatusEnum.Warning" @onclick="ButtonEditClickerHandler">Edit</Button>
            }
        </ButtonList>

    </div>

    @if (!_isEditMode)
    {
        <div>
            <strong>Schema Identifier:</strong>
            @SchemaContext.SchemaIdentifier
        </div>
        <div>
            <strong>Name:</strong>
            @SchemaContext.Name
        </div>
        <div>
            <strong>Note:</strong>
            @SchemaContext.Note
        </div>
        <div>
            <strong>Created at:</strong>
            @SchemaContext.TimeCreated
        </div>
        <div>
            <strong>Title:</strong>
            @SchemaContext.TitleTextParameter?.Name
        </div>
        <div>
            <strong>Description:</strong>
            @SchemaContext.DescriptionTextParameter?.Name
        </div>
    }
    else
    {
        <FormSchemaContextUpdate SchemaContext="SchemaContext" OnSubmit="FormEditSubmitHandler">
            <div class="action-list">
                <Button Status="StatusEnum.Success" Loading="IsLoadingUpdate" type="submit">
                    @TextService.Get(ParameterTextConstants.ButtonUpdate)
                </Button>

                <Button Status="StatusEnum.Error" Loading="IsLoadingUpdate" type="button" @onclick="ButtonEditCancelHandler">
                    @TextService.Get(ParameterTextConstants.ButtonCancel)
                </Button>
            </div>
        </FormSchemaContextUpdate>
    }

</div>

@code {

    [Parameter, EditorRequired]
    public required EntitySchema Schema { get; set; }

    [Parameter, EditorRequired]
    public required EntitySchemaContext SchemaContext { get; set; }

    [Parameter]
    public string? Scope { get; set; }
    private string ScopeCurrent => Scope ?? GetComponentName();

    [Parameter]
    public HTMLHeaderLevelEnum? HeaderLevel { get; set; }
    private HTMLHeaderLevelEnum HeaderLevelCurrent => HeaderLevel ?? HTMLHeaderLevelEnum.H3;

    private bool _isEditMode;

    private string Size => $"var(--size-text-{HeaderLevelCurrent.ToText()})";
    private string Link => $"/schema/{Schema.ID}/context/{SchemaContext.ID}";
    private bool IsLoadingUpdate => StateSchemaContext.Value.TryGetLoading(ScopeCurrent, FeatureSchemaContextActionKind.Update, out bool value) && value;

    private void ButtonEditClickerHandler()
    {
        _isEditMode = true;
    }

    private void FormEditSubmitHandler(IWebFormContext<RequestSchemaContextUpdate> value)
    {
        Dispatcher.Dispatch(new FeatureSchemaContextReducers.UpdateAction(ScopeCurrent, value.Model));
        _isEditMode = false;
    }

    private void ButtonEditCancelHandler()
    {
        _isEditMode = false;
    }

    private void OnButtonDeleteClick()
    {
        Dispatcher.Dispatch(new FeatureSchemaContextReducers.DeleteAction(ScopeCurrent, new() { ID = SchemaContext.ID }));
    }

    private void OnButtonCloneClick()
    {
        Dispatcher.Dispatch(new FeatureSchemaContextReducers.CloneAction(ScopeCurrent, new() { ID = SchemaContext.ID }));
    }

}
