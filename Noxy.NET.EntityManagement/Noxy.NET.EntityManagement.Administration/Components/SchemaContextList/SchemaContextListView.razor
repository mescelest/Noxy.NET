@inject IState<FeatureSchemaContextState> StateContext
@inject IDispatcher Dispatcher
@inherits FluxorElementComponent

<div @attributes="AdditionalAttributes" class="@CssClass">
    <Loader Loading="IsLoading">

        <div class="header">
            <DynamicHTMLTag Tag="@HeaderLevelCurrent.ToText()">List of contexts</DynamicHTMLTag>
            <InputElementPagination PageSize="@(Request.PageSize ?? 10)" Count="Count" @bind-Value="Request.PageNumber" @bind-Value:after="Callback"/>
        </div>

        @foreach (EntitySchemaContext entitySchemaContext in List)
        {
            @ChildContent(entitySchemaContext)
        }
    </Loader>
</div>

@code {

    [Parameter]
    public Guid? SchemaID { get; set; }

    [Parameter, EditorRequired]
    public RenderFragment<EntitySchemaContext> ChildContent { get; set; }

    [Parameter]
    public HTMLHeaderLevelEnum? HeaderLevel { get; set; }
    private HTMLHeaderLevelEnum HeaderLevelCurrent => HeaderLevel ?? HTMLHeaderLevelEnum.H1;

    [Parameter]
    public RequestSchemaContextList? InitialRequest { get; set; }
    private RequestSchemaContextList InitialRequestCurrent => InitialRequest ?? new() { SchemaID = SchemaID };

    [Parameter]
    public string? Scope { get; set; }
    private string ScopeCurrent => Scope ?? $"{GetComponentName()}:{SchemaID}";

    private bool IsLoading => StateContext.Value.TryGetLoading(ScopeCurrent, FeatureSchemaContextActionKind.List, out bool value) && value;
    private IReadOnlyList<EntitySchemaContext> List => StateContext.Value.TryGetList(ScopeCurrent, out IReadOnlyList<EntitySchemaContext>? list) ? list : [];
    private RequestSchemaContextList Request => StateContext.Value.TryGetRequest(ScopeCurrent, out RequestSchemaContextList? request) ? request : InitialRequestCurrent;
    private int Count => StateContext.Value.TryGetCount(ScopeCurrent, out int count) ? count : 0;

    protected override void OnInitialized()
    {
        base.OnInitialized();

        Dispatcher.Dispatch(new FeatureSchemaContextReducers.ListAction(ScopeCurrent, InitialRequestCurrent));
        Dispatcher.Dispatch(new FeatureSchemaContextReducers.CountAction(ScopeCurrent, new()));
    }

    private void Callback()
    {
        Dispatcher.Dispatch(new FeatureSchemaContextReducers.ListAction(ScopeCurrent, Request));
    }

}
