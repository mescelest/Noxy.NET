@inject IState<FeatureSchemaPropertyState> StateSchemaProperty
@inject IDispatcher Dispatcher
@inject TextService TextService
@inherits FluxorElementComponent

<div @attributes="AdditionalAttributes" class="@CssClass">
    <div class="header">
        <div class="title">
            <DynamicHTMLTag Tag="@HeaderLevelCurrent.ToText()">@SchemaProperty.Name</DynamicHTMLTag>
            <NavLink href="@Link">
                <MaterialIcon Icon="arrow_right_alt" Size="@Size"/>
            </NavLink>
        </div>

        <ButtonList Alignment="ButtonListAlignmentEnum.Right">
            @if (Schema.TimeActivated == null)
            {
                <Button Status="StatusEnum.Error" @onclick="OnButtonDeleteClick">Delete</Button>
                <Button Status="StatusEnum.Info" @onclick="OnButtonCloneClick">Clone</Button>
                <Button Status="StatusEnum.Warning" @onclick="ButtonEditClickerHandler">Edit</Button>
            }
        </ButtonList>

    </div>

    @if (!_isEditMode)
    {
        <div>
            <strong>@TextService.Get(ParameterTextConstants.LabelSchemaIdentifier, GetComponentName()):</strong>
            @SchemaProperty.SchemaIdentifier
        </div>
        <div>
            <strong>@TextService.Get(ParameterTextConstants.LabelName, GetComponentName()):</strong>
            @SchemaProperty.Name
        </div>
        <div>
            <strong>@TextService.Get(ParameterTextConstants.LabelNote, GetComponentName()):</strong>
            @SchemaProperty.Note
        </div>

        @if (SchemaProperty is EntitySchemaPropertyDateTime propertyDateTime)
        {
            <div>
                <strong>@TextService.Get(ParameterTextConstants.LabelPropertyDateTime, GetComponentName()):</strong>
                @propertyDateTime.Type
            </div>
        }

        <div>
            <strong>@TextService.Get(ParameterTextConstants.LabelTitle, GetComponentName())</strong>
            @SchemaProperty.TitleParameterText?.Name
        </div>
        <div>
            <strong>@TextService.Get(ParameterTextConstants.LabelDescription, GetComponentName())</strong>
            @SchemaProperty.DescriptionParameterText?.Name
        </div>
        <div>
            <strong>@TextService.Get(ParameterTextConstants.LabelTimeCreated, GetComponentName()):</strong>
            @SchemaProperty.TimeCreated
        </div>
    }
    else
    {
        switch (SchemaProperty)
        {
            case EntitySchemaPropertyBoolean propertyBoolean:
                <FormSchemaPropertyBooleanUpdate SchemaProperty="propertyBoolean" OnSubmit="FormEditBooleanSubmitHandler">
                    @GetSubmitAction()
                </FormSchemaPropertyBooleanUpdate>
                break;
            case EntitySchemaPropertyDateTime propertyDateTime:
                <FormSchemaPropertyDateTimeUpdate SchemaProperty="propertyDateTime" OnSubmit="FormEditDateTimeSubmitHandler">
                    @GetSubmitAction()
                </FormSchemaPropertyDateTimeUpdate>
                break;
            case EntitySchemaPropertyDecimal propertyDecimal:
                <FormSchemaPropertyDecimalUpdate SchemaProperty="propertyDecimal" OnSubmit="FormEditDecimalSubmitHandler">
                    @GetSubmitAction()
                </FormSchemaPropertyDecimalUpdate>
                break;
            case EntitySchemaPropertyImage propertyImage:
                <FormSchemaPropertyImageUpdate SchemaProperty="propertyImage" OnSubmit="FormEditImageSubmitHandler">
                    @GetSubmitAction()
                </FormSchemaPropertyImageUpdate>
                break;
            case EntitySchemaPropertyInteger propertyInteger:
                <FormSchemaPropertyIntegerUpdate SchemaProperty="propertyInteger" OnSubmit="FormEditIntegerSubmitHandler">
                    @GetSubmitAction()
                </FormSchemaPropertyIntegerUpdate>
                break;
            case EntitySchemaPropertyString propertyString:
                <FormSchemaPropertyStringUpdate SchemaProperty="propertyString" OnSubmit="FormEditStringSubmitHandler">
                    @GetSubmitAction()
                </FormSchemaPropertyStringUpdate>
                break;
        }
    }
</div>

@code {

    [Parameter, EditorRequired]
    public EntitySchema Schema { get; set; }

    [Parameter, EditorRequired]
    public EntitySchemaProperty SchemaProperty { get; set; }

    [Parameter]
    public string? Scope { get; set; }
    private string ScopeCurrent => Scope ?? GetComponentName();

    [Parameter]
    public HTMLHeaderLevelEnum? HeaderLevel { get; set; }
    private HTMLHeaderLevelEnum HeaderLevelCurrent => HeaderLevel ?? HTMLHeaderLevelEnum.H3;

    private bool _isEditMode;

    private string Size => $"var(--size-text-{HeaderLevelCurrent.ToText()})";
    private string Link => $"/schema/{Schema.ID}/property/{SchemaProperty.ID}";
    private bool IsLoadingUpdate => StateSchemaProperty.Value.TryGetLoading(ScopeCurrent, FeatureSchemaPropertyActionKind.Update, out bool value) && value;

    private void ButtonEditClickerHandler()
    {
        _isEditMode = true;
    }

    private void ButtonEditCancelHandler()
    {
        _isEditMode = false;
    }

    private void FormEditBooleanSubmitHandler(IWebFormContext<RequestSchemaPropertyBooleanUpdate> value)
    {
        Dispatcher.Dispatch(new FeatureSchemaPropertyReducers.UpdateBooleanAction(ScopeCurrent, value.Model));
        _isEditMode = false;
    }

    private void FormEditDateTimeSubmitHandler(IWebFormContext<RequestSchemaPropertyDateTimeUpdate> value)
    {
        Dispatcher.Dispatch(new FeatureSchemaPropertyReducers.UpdateDateTimeAction(ScopeCurrent, value.Model));
        _isEditMode = false;
    }

    private void FormEditDecimalSubmitHandler(IWebFormContext<RequestSchemaPropertyDecimalUpdate> value)
    {
        Dispatcher.Dispatch(new FeatureSchemaPropertyReducers.UpdateDecimalAction(ScopeCurrent, value.Model));
        _isEditMode = false;
    }

    private void FormEditImageSubmitHandler(IWebFormContext<RequestSchemaPropertyImageUpdate> value)
    {
        Dispatcher.Dispatch(new FeatureSchemaPropertyReducers.UpdateImageAction(ScopeCurrent, value.Model));
        _isEditMode = false;
    }

    private void FormEditIntegerSubmitHandler(IWebFormContext<RequestSchemaPropertyIntegerUpdate> value)
    {
        Dispatcher.Dispatch(new FeatureSchemaPropertyReducers.UpdateIntegerAction(ScopeCurrent, value.Model));
        _isEditMode = false;
    }

    private void FormEditStringSubmitHandler(IWebFormContext<RequestSchemaPropertyStringUpdate> value)
    {
        Dispatcher.Dispatch(new FeatureSchemaPropertyReducers.UpdateStringAction(ScopeCurrent, value.Model));
        _isEditMode = false;
    }

    private void OnButtonDeleteClick()
    {
        Dispatcher.Dispatch(new FeatureSchemaPropertyReducers.DeleteAction(ScopeCurrent, new() { ID = SchemaProperty.ID }));
    }

    private void OnButtonCloneClick()
    {
        Dispatcher.Dispatch(new FeatureSchemaPropertyReducers.CloneAction(ScopeCurrent, new() { ID = SchemaProperty.ID }));
    }

    private RenderFragment GetSubmitAction()
    {
        return
            @<div class="action-list">
                <Button Status="StatusEnum.Success" Loading="IsLoadingUpdate" type="submit">
                    @TextService.Get(ParameterTextConstants.ButtonUpdate, GetComponentName())
                </Button>

                <Button Status="StatusEnum.Error" Loading="IsLoadingUpdate" type="button" @onclick="ButtonEditCancelHandler">
                    @TextService.Get(ParameterTextConstants.ButtonCancel, GetComponentName())
                </Button>
            </div>;
    }

}
