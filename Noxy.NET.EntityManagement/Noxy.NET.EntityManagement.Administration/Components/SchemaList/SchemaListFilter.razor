@inject IDispatcher Dispatcher
@inject TextService TextService
@inherits ElementComponent

<div @attributes="AdditionalAttributes" class="@CssClass">
    <DynamicHTMLTag Tag="@HeaderLevelCurrent.ToText()">Search for a schema</DynamicHTMLTag>

    <FormSchemaList OnSubmit="Submit">
        <ButtonList Alignment="ButtonListAlignmentEnum.Right">
            <Button Status="StatusEnum.Warning" type="button">
                @Presentation.Services.TextService.Get(ParameterTextConstants.ButtonReset)
            </Button>
            <Button Status="StatusEnum.Info" type="submit">
                @Presentation.Services.TextService.Get(ParameterTextConstants.ButtonFilter)
            </Button>
        </ButtonList>
    </FormSchemaList>
</div>

@code {

    [Parameter]
    public string? Scope { get; set; }
    private string ScopeCurrent => Scope ?? GetComponentName();

    [Parameter]
    public HTMLHeaderLevelEnum? HeaderLevel { get; set; }
    private HTMLHeaderLevelEnum HeaderLevelCurrent => HeaderLevel ?? HTMLHeaderLevelEnum.H1;

    private void Submit(IWebFormContext<RequestSchemaList> value)
    {
        Dispatcher.Dispatch(new FeatureSchemaReducers.ListAction(ScopeCurrent, value.Model));
        Dispatcher.Dispatch(new FeatureSchemaReducers.CountAction(ScopeCurrent, new()
        {
                Search = value.Model.Search,
                IsActivated = value.Model.IsActivated,
        }));
    }

}