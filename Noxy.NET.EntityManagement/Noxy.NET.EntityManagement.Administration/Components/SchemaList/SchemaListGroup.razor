@inject IState<FeatureSchemaState> StateSchema
@inject IDispatcher Dispatcher
@inject TextParameterService TextParameterService
@inject SystemParameterService SystemParameterService
@inherits FluxorElementComponent

<div @attributes="AdditionalAttributes" class="@CssClass">
    <div class="header">
        <div class="title">
            <DynamicHTMLTag Tag="@HeaderLevelCurrent.ToText()">@Schema.Name</DynamicHTMLTag>
            <NavLink href="@Link">
                <MaterialIcon Icon="arrow_right_alt" Size="@Size"/>
            </NavLink>
        </div>
        <ButtonList Alignment="ButtonListAlignmentEnum.Right">
            @if (!Schema.IsActive)
            {
                <Button Status="StatusEnum.Success" @onclick="OnButtonActivateClick">Activate</Button>

                @if (SystemParameterService.CanPerformSchemaAction(Schema, ParameterSystemConstants.SchemaInactiveEntityEdit, ParameterSystemConstants.SchemaDeactivatedEntityEdit))
                {
                    <Button Status="StatusEnum.Warning" @onclick="ButtonEditClickerHandler">Edit</Button>
                }

                @if (SystemParameterService.CanPerformSchemaAction(Schema, ParameterSystemConstants.SchemaInactiveEntityDelete, ParameterSystemConstants.SchemaDeactivatedEntityDelete))
                {
                    <Button Status="StatusEnum.Error" @onclick="OnButtonDeleteClick">Delete</Button>
                }
            }

            <Button Status="StatusEnum.Info" @onclick="OnButtonCloneClick">Clone</Button>
        </ButtonList>

    </div>

    @if (!_isEditMode)
    {
        <span class="note">
            @Schema.Note
        </span>

        <div>
            <strong>Created at:</strong>
            @Schema.TimeCreated
        </div>
        <div>
            <strong>Is active:</strong>
            @Schema.IsActive
        </div>
        <div>
            <strong>Activated at:</strong>
            @Schema.TimeActivated
        </div>
    }
    else
    {
        <FormSchemaUpdate Schema="Schema" OnSubmit="FormEditSubmitHandler">
            <div class="action-list">
                <Button Status="StatusEnum.Success" Loading="IsLoadingUpdate" type="submit">
                    @TextParameterService.Get(ParameterTextConstants.ButtonUpdate)
                </Button>

                <Button Status="StatusEnum.Error" Loading="IsLoadingUpdate" type="button" @onclick="ButtonEditCancelHandler">
                    @TextParameterService.Get(ParameterTextConstants.ButtonCancel)
                </Button>
            </div>
        </FormSchemaUpdate>
    }

    <TabSet>
        <TabPage Title="@TextParameterService.Get(ParameterTextConstants.HeaderContextList)" Link="@LinkContext">
            <ChildContent>
                <SchemaListContextView SchemaID="@Schema.ID" Scope="@Schema.ID.ToString()" HeaderLevel="HeaderLevelCurrent.GetNext()"/>
            </ChildContent>
            <LinkContent>
                <MaterialIcon Icon="arrow_right"/>
            </LinkContent>
        </TabPage>

        <TabPage Title="@TextParameterService.Get(ParameterTextConstants.HeaderElementList)">
            <SchemaListElementView SchemaID="@Schema.ID" Scope="@Schema.ID.ToString()" HeaderLevel="HeaderLevelCurrent.GetNext()"/>
        </TabPage>

        <TabPage Title="@TextParameterService.Get(ParameterTextConstants.HeaderParameterList)">
            <SchemaListParameterView SchemaID="@Schema.ID" Scope="@Schema.ID.ToString()" HeaderLevel="HeaderLevelCurrent.GetNext()"/>
        </TabPage>

        <TabPage Title="@TextParameterService.Get(ParameterTextConstants.HeaderPropertyList)">
            <SchemaListPropertyView SchemaID="@Schema.ID" Scope="@Schema.ID.ToString()" HeaderLevel="HeaderLevelCurrent.GetNext()"/>
        </TabPage>
    </TabSet>

</div>

@code {

    [Parameter, EditorRequired]
    public required EntitySchema Schema { get; set; }

    [Parameter]
    public string? Scope { get; set; }
    private string ScopeCurrent => Scope ?? GetComponentName();

    [Parameter]
    public HTMLHeaderLevelEnum? HeaderLevel { get; set; }
    private HTMLHeaderLevelEnum HeaderLevelCurrent => HeaderLevel ?? HTMLHeaderLevelEnum.H3;

    private bool _isEditMode;

    private string Size => $"var(--size-text-{HeaderLevelCurrent.ToText()})";
    private string Link => $"/schema/{Schema.ID}";
    private bool IsLoadingUpdate => StateSchema.Value.TryGetLoading(ScopeCurrent, FeatureSchemaActionKind.Update, out bool value) && value;

    private string LinkContext => $"/schema/{Schema.ID}/context";

    private void ButtonEditClickerHandler()
    {
        _isEditMode = true;
    }

    private void FormEditSubmitHandler(IWebFormContext<RequestSchemaUpdate> value)
    {
        Dispatcher.Dispatch(new FeatureSchemaReducers.UpdateAction(ScopeCurrent, value.Model));
        _isEditMode = false;
    }

    private void ButtonEditCancelHandler()
    {
        _isEditMode = false;
    }

    private void OnButtonActivateClick()
    {
        Dispatcher.Dispatch(new FeatureSchemaReducers.ActivateAction(ScopeCurrent, new() { ID = Schema.ID }));
    }

    private void OnButtonDeleteClick()
    {
        Dispatcher.Dispatch(new FeatureSchemaReducers.DeleteAction(ScopeCurrent, new() { ID = Schema.ID }));
    }

    private void OnButtonCloneClick()
    {
        Dispatcher.Dispatch(new FeatureSchemaReducers.CloneAction(ScopeCurrent, new() { ID = Schema.ID }));
    }

}
