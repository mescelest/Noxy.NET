@inject IState<FeatureSchemaState> StateSchema
@inject IDispatcher Dispatcher
@inject TextService TextService
@inherits FluxorElementComponent

<div @attributes="AdditionalAttributes" class="@CssClass">
    <div class="header">
        <div class="title">
            <DynamicHTMLTag Tag="@HeaderLevelCurrent.ToText()">@Schema.Name</DynamicHTMLTag>
            <NavLink href="@Link">
                <MaterialIcon Icon="arrow_right_alt" Size="@Size"/>
            </NavLink>
        </div>
        <div class="action-list">
            @if (!Schema.IsActive)
            {
                <Button Status="StatusEnum.Success" @onclick="OnButtonActivateClick">Activate</Button>
            }

            @if (Schema.TimeActivated == null)
            {
                <Button Status="StatusEnum.Error" @onclick="OnButtonDeleteClick">Delete</Button>
            }

            <Button Status="StatusEnum.Info" @onclick="OnButtonCloneClick">Clone</Button>
            <Button Status="StatusEnum.Warning" @onclick="OnButtonEditClick">Edit</Button>
        </div>

    </div>

    @if (!_isEditMode)
    {
        <div>
            <strong>Name:</strong>
            @Schema.Name
        </div>
        <div>
            <strong>Note:</strong>
            @Schema.Note
        </div>
        <div>
            <strong>Created at:</strong>
            @Schema.TimeCreated
        </div>
        <div>
            <strong>Is active:</strong>
            @Schema.IsActive
        </div>
        <div>
            <strong>Activated at:</strong>
            @Schema.TimeActivated
        </div>
    }
    else
    {
        <FormSchemaUpdate Schema="Schema" OnSubmit="OnButtonEditSubmit">
            <div class="action-list">
                <Button Status="StatusEnum.Success" Loading="IsLoadingUpdate" type="submit">
                    @TextService.Get(TextConstants.ButtonUpdate)
                </Button>

                <Button Status="StatusEnum.Error" Loading="IsLoadingUpdate" type="button" @onclick="OnButtonEditCancel">
                    @TextService.Get(TextConstants.ButtonCancel)
                </Button>
            </div>
        </FormSchemaUpdate>
    }

    <SchemaListElementView SchemaID="@Schema.ID" Context="@Schema.ID.ToString()" HeaderLevel="HeaderLevelCurrent.GetNext()"/>

    <SchemaListContextView SchemaID="@Schema.ID" Context="@Schema.ID.ToString()" HeaderLevel="HeaderLevelCurrent.GetNext()"/>

</div>

@code {

    [Parameter, EditorRequired]
    public required EntitySchema Schema { get; set; }

    [Parameter]
    public string? Context { get; set; }
    private string ContextCurrent => Context ?? GetComponentName();

    [Parameter]
    public HTMLHeaderLevelEnum? HeaderLevel { get; set; }
    private HTMLHeaderLevelEnum HeaderLevelCurrent => HeaderLevel ?? HTMLHeaderLevelEnum.H3;

    private bool _isEditMode;

    private string Size => $"var(--size-text-{HeaderLevelCurrent.ToText()})";
    private string Link => $"/schema/{Schema.ID}";
    private bool IsLoadingUpdate => StateSchema.Value.TryGetLoading(ContextCurrent, FeatureSchemaActionKind.Update, out bool value) && value;

    private void OnButtonEditClick()
    {
        _isEditMode = true;
    }

    private void OnButtonEditSubmit(IWebFormContext<RequestSchemaUpdate> value)
    {
        Dispatcher.Dispatch(new FeatureSchemaReducers.SchemaUpdateAction(ContextCurrent, value.Model));
        _isEditMode = false;
    }

    private void OnButtonEditCancel()
    {
        _isEditMode = false;
    }

    private void OnButtonActivateClick()
    {
        Dispatcher.Dispatch(new FeatureSchemaReducers.SchemaActivateAction(ContextCurrent, new() { ID = Schema.ID }));
    }

    private void OnButtonDeleteClick()
    {
        Dispatcher.Dispatch(new FeatureSchemaReducers.SchemaDeleteAction(ContextCurrent, new() { ID = Schema.ID }));
    }

    private void OnButtonCloneClick()
    {
        Dispatcher.Dispatch(new FeatureSchemaReducers.SchemaCloneAction(ContextCurrent, new() { ID = Schema.ID }));
    }

}
