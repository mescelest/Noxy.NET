@inject IState<FeatureSchemaParameterState> StateContext
@inject TextService TextService
@inject IDispatcher Dispatcher
@inherits FluxorElementComponent

<div @attributes="AdditionalAttributes" class="@CssClass">
    <Collapsible Loading="IsLoading" @bind-Collapsed:get="_isCollapsed" @bind-Collapsed:set="SetCollapsed">
        <Header>
            <div class="title">
                <DynamicHTMLTag Tag="@HeaderLevelCurrent.ToText()">Parameter list</DynamicHTMLTag>
                <NavLink href="@Link">
                    <MaterialIcon Icon="arrow_right_alt" Size="@Size"/>
                </NavLink>
            </div>
        </Header>
        <Content>
            <div class="grid">
                <div class="grid-header">
                    <strong>@TextService.Get(TextConstants.LabelSchemaIdentifier)</strong>
                    <strong>@TextService.Get(TextConstants.LabelName)</strong>
                    <strong>@TextService.Get(TextConstants.LabelNote)</strong>
                    <strong>@TextService.Get(TextConstants.LabelTitle)</strong>
                    <strong>@TextService.Get(TextConstants.LabelDescription)</strong>
                    <strong>@TextService.Get(TextConstants.LabelTimeCreated)</strong>
                </div>
                @foreach (EntitySchemaParameter.Discriminator item in List)
                {
                    EntitySchemaParameter parameter = @item.GetValue();

                    <div class="grid-row">
                        <span>@parameter.SchemaIdentifier</span>
                        <span>@parameter.Name</span>
                        <span>@parameter.Note</span>
                        <span>@parameter.IsApprovalRequired</span>
                        <span>@parameter.IsSystemDefined</span>
                        <span>@parameter.TimeCreated</span>
                    </div>
                }
            </div>
        </Content>
    </Collapsible>
</div>

@code {

    [Parameter, EditorRequired]
    public required Guid SchemaID { get; set; }

    [Parameter]
    public HTMLHeaderLevelEnum? HeaderLevel { get; set; }
    private HTMLHeaderLevelEnum HeaderLevelCurrent => HeaderLevel ?? HTMLHeaderLevelEnum.H4;

    [Parameter]
    public string? Scope { get; set; }
    private string ScopeCurrent => Scope ?? $"{GetComponentName()}:{SchemaID}";

    private bool _isCollapsed = true;

    private string Size => $"var(--size-text-{HeaderLevelCurrent.ToText()})";
    private string Link => $"/schema/{SchemaID}/parameter";
    private bool IsLoading => StateContext.Value.TryGetLoading(ScopeCurrent, FeatureSchemaParameterActionKind.List, out bool value) && value;
    private IReadOnlyList<EntitySchemaParameter.Discriminator> List => StateContext.Value.TryGetList(ScopeCurrent, out IReadOnlyList<EntitySchemaParameter.Discriminator>? value) ? value : [];

    private void SetCollapsed(bool value)
    {
        _isCollapsed = value;
        if (_isCollapsed || StateContext.Value.Cache.ContainsKey(ScopeCurrent) || IsLoading) return;
        Dispatcher.Dispatch(new FeatureSchemaParameterReducers.ListAction(ScopeCurrent, new() { SchemaID = SchemaID }));
    }

}
