@inject IState<FeatureSchemaParameterState> State
@inject IDispatcher Dispatcher
@inherits FluxorElementComponent

<div @attributes="AdditionalAttributes" class="@CssClass">
    <DynamicHTMLTag Tag="@HeaderLevelCurrent.ToText()">List of schema parameters</DynamicHTMLTag>

    <Loader Loading="IsLoading">
        @foreach (EntitySchemaParameter.Discriminator item in List)
        {
            @ChildContent(item)
        }
    </Loader>
</div>

@code {

    [Parameter, EditorRequired]
    public RenderFragment<EntitySchemaParameter.Discriminator> ChildContent { get; set; }

    [Parameter]
    public HTMLHeaderLevelEnum? HeaderLevel { get; set; }
    private HTMLHeaderLevelEnum HeaderLevelCurrent => HeaderLevel ?? HTMLHeaderLevelEnum.H1;

    [Parameter]
    public RequestSchemaParameterList? Request { get; set; }
    private RequestSchemaParameterList RequestCurrent => Request ?? new();

    [Parameter]
    public string? Scope { get; set; }
    private string ScopeCurrent => Scope ?? GetComponentName();

    private bool IsLoading => State.Value.TryGetLoading(ScopeCurrent, FeatureSchemaParameterActionKind.List, out bool value) && value;
    private IReadOnlyList<EntitySchemaParameter.Discriminator> List => State.Value.TryGetList(ScopeCurrent, out IReadOnlyList<EntitySchemaParameter.Discriminator>? list) ? list : [];

    protected override void OnInitialized()
    {
        base.OnInitialized();

        if (List.Count == 0 && !IsLoading)
        {
            Dispatcher.Dispatch(new FeatureSchemaParameterReducers.ListAction(ScopeCurrent, RequestCurrent));
        }
    }

}