@inject IState<FeatureSchemaElementState> StateSchemaElement
@inject IDispatcher Dispatcher
@inject TextParameterService TextParameterService
@inject SystemParameterService SystemParameterService
@inherits FluxorElementComponent

<div @attributes="AdditionalAttributes" class="@CssClass">
    <div class="header">
        <div class="title">
            <DynamicHTMLTag Tag="@HeaderLevelCurrent.ToText()">@SchemaElement.Name</DynamicHTMLTag>
            <NavLink href="@Link">
                <MaterialIcon Icon="arrow_right_alt" Size="@Size"/>
            </NavLink>
        </div>

        @if (!Schema.IsActive)
        {
            <ButtonList Alignment="ButtonListAlignmentEnum.Right">
                @if (SystemParameterService.CanPerformSchemaAction(Schema, ParameterSystemConstants.SchemaInactiveElementDelete, ParameterSystemConstants.SchemaDeactivatedElementDelete))
                {
                    <Button Status="StatusEnum.Error" @onclick="OnButtonDeleteClick">Delete</Button>
                }
                @if (SystemParameterService.CanPerformSchemaAction(Schema, ParameterSystemConstants.SchemaInactiveElementClone, ParameterSystemConstants.SchemaDeactivatedElementClone))
                {
                    <Button Status="StatusEnum.Info" @onclick="OnButtonCloneClick">Clone</Button>
                }
                @if (SystemParameterService.CanPerformSchemaAction(Schema, ParameterSystemConstants.SchemaInactiveElementEdit, ParameterSystemConstants.SchemaDeactivatedElementEdit))
                {
                    <Button Status="StatusEnum.Warning" @onclick="ButtonEditClickerHandler">Edit</Button>
                }
            </ButtonList>
        }

    </div>

    @if (!_isEditMode)
    {
        <div>
            <strong>@TextParameterService.Get(ParameterTextConstants.LabelSchemaIdentifier, GetComponentName()):</strong>
            @SchemaElement.SchemaIdentifier
        </div>
        <div>
            <strong>@TextParameterService.Get(ParameterTextConstants.LabelName, GetComponentName()):</strong>
            @SchemaElement.Name
        </div>
        <div>
            <strong>@TextParameterService.Get(ParameterTextConstants.LabelNote, GetComponentName()):</strong>
            @SchemaElement.Note
        </div>
        <div>
            <strong>@TextParameterService.Get(ParameterTextConstants.LabelWeight, GetComponentName()):</strong>
            @SchemaElement.Weight
        </div>
        <div>
            <strong>@TextParameterService.Get(ParameterTextConstants.LabelTitle, GetComponentName()):</strong>
            @SchemaElement.TitleTextParameter?.Name
        </div>
        <div>
            <strong>@TextParameterService.Get(ParameterTextConstants.LabelDescription, GetComponentName()):</strong>
            @SchemaElement.DescriptionTextParameter?.Name
        </div>
        <div>
            <strong>@TextParameterService.Get(ParameterTextConstants.LabelTimeCreated, GetComponentName()):</strong>
            @SchemaElement.TimeCreated
        </div>
    }
    else
    {
        <FormSchemaElementUpdate SchemaElement="SchemaElement" OnSubmit="FormEditSubmitHandler">
            <div class="action-list">
                <Button Status="StatusEnum.Success" Loading="IsLoadingUpdate" type="submit">
                    @TextParameterService.Get(ParameterTextConstants.ButtonUpdate)
                </Button>

                <Button Status="StatusEnum.Error" Loading="IsLoadingUpdate" type="button" @onclick="ButtonEditCancelHandler">
                    @TextParameterService.Get(ParameterTextConstants.ButtonCancel)
                </Button>
            </div>
        </FormSchemaElementUpdate>
    }

</div>

@code {

    [Parameter, EditorRequired]
    public required EntitySchema Schema { get; set; }

    [Parameter, EditorRequired]
    public required EntitySchemaElement SchemaElement { get; set; }

    [Parameter]
    public string? Scope { get; set; }
    private string ScopeCurrent => Scope ?? GetComponentName();

    [Parameter]
    public HTMLHeaderLevelEnum? HeaderLevel { get; set; }
    private HTMLHeaderLevelEnum HeaderLevelCurrent => HeaderLevel ?? HTMLHeaderLevelEnum.H3;

    private bool _isEditMode;

    private string Size => $"var(--size-text-{HeaderLevelCurrent.ToText()})";
    private string Link => $"/schema/{Schema.ID}/element/{SchemaElement.ID}";
    private bool IsLoadingUpdate => StateSchemaElement.Value.TryGetLoading(ScopeCurrent, FeatureSchemaElementActionKind.Update, out bool value) && value;

    private void ButtonEditClickerHandler()
    {
        _isEditMode = true;
    }

    private void FormEditSubmitHandler(IWebFormContext<RequestSchemaElementUpdate> value)
    {
        Dispatcher.Dispatch(new FeatureSchemaElementReducers.UpdateAction(ScopeCurrent, value.Model));
        _isEditMode = false;
    }

    private void ButtonEditCancelHandler()
    {
        _isEditMode = false;
    }

    private void OnButtonDeleteClick()
    {
        Dispatcher.Dispatch(new FeatureSchemaElementReducers.DeleteAction(ScopeCurrent, new() { ID = SchemaElement.ID }));
    }

    private void OnButtonCloneClick()
    {
        Dispatcher.Dispatch(new FeatureSchemaElementReducers.CloneAction(ScopeCurrent, new() { ID = SchemaElement.ID }));
    }

}
