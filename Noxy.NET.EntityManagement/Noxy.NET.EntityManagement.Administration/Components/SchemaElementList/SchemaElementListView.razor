@inject IState<FeatureSchemaElementState> StateElement
@inject IDispatcher Dispatcher
@inherits FluxorElementComponent

<div @attributes="AdditionalAttributes" class="@CssClass">
    <Loader Loading="IsLoading">

        <div class="header">
            <DynamicHTMLTag Tag="@HeaderLevelCurrent.ToText()">List of elements</DynamicHTMLTag>
            <InputElementPagination PageSize="@(Request.PageSize ?? 10)" Count="Count" @bind-Value="Request.PageNumber" @bind-Value:after="Callback"/>
        </div>

        @foreach (EntitySchemaElement entitySchemaElement in List)
        {
            @ChildContent(entitySchemaElement)
        }
    </Loader>
</div>

@code {

    [Parameter]
    public Guid? SchemaID { get; set; }

    [Parameter, EditorRequired]
    public RenderFragment<EntitySchemaElement> ChildContent { get; set; }

    [Parameter]
    public HTMLHeaderLevelEnum? HeaderLevel { get; set; }
    private HTMLHeaderLevelEnum HeaderLevelCurrent => HeaderLevel ?? HTMLHeaderLevelEnum.H1;

    [Parameter]
    public RequestSchemaElementList? InitialRequest { get; set; }
    private RequestSchemaElementList InitialRequestCurrent => InitialRequest ?? new() { SchemaID = SchemaID };

    [Parameter]
    public string? Scope { get; set; }
    private string ScopeCurrent => Scope ?? $"{ComponentName}:{SchemaID}";

    private bool IsLoading => StateElement.Value.TryGetLoading(ScopeCurrent, FeatureSchemaElementActionKind.List, out bool value) && value;
    private IReadOnlyList<EntitySchemaElement> List => StateElement.Value.TryGetList(ScopeCurrent, out IReadOnlyList<EntitySchemaElement>? list) ? list : [];
    private RequestSchemaElementList Request => StateElement.Value.TryGetRequest(ScopeCurrent, out RequestSchemaElementList? request) ? request : InitialRequestCurrent;
    private int Count => StateElement.Value.TryGetCount(ScopeCurrent, out int count) ? count : 0;

    protected override void OnInitialized()
    {
        base.OnInitialized();

        Dispatcher.Dispatch(new FeatureSchemaElementReducers.ListAction(ScopeCurrent, InitialRequestCurrent));
        Dispatcher.Dispatch(new FeatureSchemaElementReducers.CountAction(ScopeCurrent, new()));
    }

    private void Callback()
    {
        Dispatcher.Dispatch(new FeatureSchemaElementReducers.ListAction(ScopeCurrent, Request));
    }

}
