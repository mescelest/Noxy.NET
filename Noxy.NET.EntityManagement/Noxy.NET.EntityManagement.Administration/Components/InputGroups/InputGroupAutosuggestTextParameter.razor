@inject IState<FeatureSchemaParameterState> State
@inject IDispatcher Dispatcher
@inherits FluxorInputGroupComponent<EntitySchemaParameterText?>

<InputGroupAutosuggest Name="@Name" DisplayName="@DisplayNameCurrent" Description="@DescriptionCurrent" InputAttributes="@InputAttributes"
                       TOption="EntitySchemaParameterText" OptionList="@Set" Loading="Loading" MinLengthText="Write more characters" NoResultText="No text parameters match your search"
                       DisplaySelector="@(c => c?.Name ?? "")" OnSearch="TitleSearchHandler" Value="@Value" ValueChanged="ValueChanged" ValueExpression="ValueExpression"/>

@code {

    [Parameter]
    public Guid? SchemaID { get; set; }

    [Parameter]
    public int? Count { get; set; }

    private string RequestContext => $"Autosuggest:{UUIDCode}";
    private bool Loading => State.Value.TryGetLoading(RequestContext, FeatureSchemaParameterActionKind.List, out bool loading) && loading;
    private IReadOnlyList<EntitySchemaParameter.Discriminator> List => State.Value.TryGetList(RequestContext, out IReadOnlyList<EntitySchemaParameter.Discriminator>? list) ? list : [];
    private HashSet<EntitySchemaParameterText> Set => List.Select(x => x.TextParameter).OfType<EntitySchemaParameterText>().ToHashSet();

    private void TitleSearchHandler(string obj)
    {
        Dispatcher.Dispatch(new FeatureSchemaParameterReducers.SchemaParameterListAction(RequestContext, new()
        {
                SchemaID = SchemaID,
                PageSize = Count,
            Search = obj,
            ParameterType = [nameof(EntitySchemaParameterText)],
        }));
    }

}