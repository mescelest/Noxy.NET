@inherits BaseRequestForm<RequestSchemaList, ResponseSchemaList>

<div @attributes="AdditionalAttributes" class="@CssClass">
    <WebForm T="RequestSchemaList" Context="Context" OnSubmit="ForwardSubmit">
        <InputGroupText DisplayName="@GetDisplayName(nameof(Model.Search))" Description="@GetDescription(nameof(Model.Search))"
                        @bind-Value="Model.Search"/>

        <InputGroupSelect OptionList="IsSystemDefinedKeys" DisplayName="@GetDisplayName(nameof(Model.IsActivated))" Description="@GetDescription(nameof(Model.IsActivated))"
                          Name="@nameof(Model.IsActivated)" @bind-Value:get="Model.IsActivated.ToTriState()" @bind-Value:set="SetIsActivated">
            <span>@TextService.Get(CollectionIsSystemDefined[context])</span>
        </InputGroupSelect>

        <InputGroupSelectSorting OptionSet="SortOptionSet" DisplayName="@GetDisplayName(nameof(Model.Sorting))" Description="@GetDescription(nameof(Model.Sorting))" @bind-Value="@Model.Sorting"/>

        <InputGroupSelectPageSize DisplayName="@GetDisplayName(nameof(Model.PageSize))" Description="@GetDescription(nameof(Model.PageSize))" @bind-Value="Model.PageSize"/>

        @ChildContent
    </WebForm>
</div>

@code {

    private static readonly Dictionary<string, string> SortOptionSet = new()
    {
        { nameof(EntitySchema.ID), TextConstants.LabelID },
        { nameof(EntitySchema.Name), TextConstants.LabelName },
        { nameof(EntitySchema.TimeCreated), TextConstants.LabelTimeCreated },
        { nameof(EntitySchema.TimeActivated), TextConstants.LabelTimeActivated },
    };

    private static readonly Dictionary<int, string> CollectionIsSystemDefined = new()
    {
        { -1, TextConstants.ValueIsActivatedNeutral },
        { 0, TextConstants.ValueIsActivatedYes },
        { 1, TextConstants.ValueIsActivatedNo }
    };

    private static readonly HashSet<int> IsSystemDefinedKeys = [..CollectionIsSystemDefined.Keys];

    protected override WebFormContext<RequestSchemaList> CreateContext()
    {
        return new(new() { SortColumn = nameof(EntitySchema.TimeCreated), SortDirection = ListSortDirection.Descending });
    }

    private void SetIsActivated(int value) => Model.IsActivated = value.FromTriState();

}
