@page "/Parameter"
@using Noxy.NET.EntityManagement.Administration.Components.DataParameterList
@inherits PageComponent

<PageTitle>Administration | Parameter</PageTitle>

<div class="@CssClass">
    <MagazineFrame>
        <Left>
            <SchemaParameterListFilter Scope="@Scope" HeaderLevel="HTMLHeaderLevelEnum.H2"/>
        </Left>
        <Content>
            <SchemaParameterListView Scope="@Scope" HeaderLevel="HTMLHeaderLevelEnum.H1">
                <DataParameterListGroup Scope="@GetGroupScope(context)" SchemaParameter="context"/>
            </SchemaParameterListView>
        </Content>
    </MagazineFrame>
</div>

@code {

    private string Scope => GetComponentName();

    private string GetGroupScope(EntitySchemaParameter parameter) => $"{Scope}:{parameter.SchemaIdentifier}";

}
