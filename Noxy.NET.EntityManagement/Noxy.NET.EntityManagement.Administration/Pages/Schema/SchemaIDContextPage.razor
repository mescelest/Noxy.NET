@page "/Schema/{ID:guid}/Context"
@inherits PageComponent

<PageTitle>Administration | Context</PageTitle>

<div class="@CssClass">
    <MagazineFrame>
        <Left>
            <SchemaContextListFilter Context="@Context" SchemaID="ID" HeaderLevel="HTMLHeaderLevelEnum.H2"/>
        </Left>
        <Content>
            <SchemaContextListView Context="@Context" SchemaID="ID" HeaderLevel="HTMLHeaderLevelEnum.H1"/>
        </Content>
        <Right>
            <SchemaContextListCreate Context="@Context" SchemaID="ID" HeaderLevel="HTMLHeaderLevelEnum.H2"/>
        </Right>
    </MagazineFrame>
</div>

@code {

    [Parameter]
    public Guid ID { get; set; }

    private string Context => GetComponentName();

}
