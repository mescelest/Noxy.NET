@page "/Schema"
@inherits PageComponent

<PageTitle>Administration | Parameter</PageTitle>

<div class="@CssClass">
    <MagazineFrame>
        <Left>
            <SchemaListFilter Context="@Context" HeaderLevel="HTMLHeaderLevelEnum.H2"/>
        </Left>
        <Content>
            <SchemaListView Context="@Context" HeaderLevel="HTMLHeaderLevelEnum.H1"/>
        </Content>
        <Right>
            <SchemaListCreate Context="@Context" HeaderLevel="HTMLHeaderLevelEnum.H2"/>
        </Right>
    </MagazineFrame>
</div>

@code {

    private string Context => GetComponentName();

}
