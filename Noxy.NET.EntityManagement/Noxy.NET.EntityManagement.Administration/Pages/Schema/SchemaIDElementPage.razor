@page "/Schema/{ID:guid}/Element"
@inherits PageComponent

<PageTitle>Administration | Element</PageTitle>

<div class="@CssClass">
    <MagazineFrame>
        <Left>
            <SchemaElementListFilter Scope="@Scope" SchemaID="ID" HeaderLevel="HTMLHeaderLevelEnum.H2"/>
        </Left>
        <Content>
            <SchemaElementListView Scope="@Scope" SchemaID="ID" HeaderLevel="HTMLHeaderLevelEnum.H1">
                <SchemaElementListGroup Schema="context.Schema" SchemaElement="context.SchemaElement" Scope="@Scope" HeaderLevel="HTMLHeaderLevelEnum.H2"/>
            </SchemaElementListView>
        </Content>
        <Right>
            <SchemaParameterListCreate Scope="@Scope" SchemaID="ID" HeaderLevel="HTMLHeaderLevelEnum.H2"/>
        </Right>
    </MagazineFrame>
</div>

@code {

    [Parameter]
    public Guid ID { get; set; }

    private string Scope => ID.ToString();

}
