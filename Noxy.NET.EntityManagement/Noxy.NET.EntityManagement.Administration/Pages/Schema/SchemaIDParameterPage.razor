@page "/Schema/{ID:guid}/Parameter"
@inject IState<FeatureSchemaState> StateSchema
@inject IDispatcher Dispatcher
@inherits FluxorPageComponent

<PageTitle>Administration | Parameter</PageTitle>

<Loader Loading="@IsLoading">
    <div class="@CssClass">
        @if (Schema != null)
        {
            <MagazineFrame>
                <Left>
                    <SchemaParameterListFilter Scope="@Scope" SchemaID="ID" HeaderLevel="HTMLHeaderLevelEnum.H2"/>
                </Left>
                <Content>
                    <SchemaParameterListView Scope="@Scope" SchemaID="ID" HeaderLevel="HTMLHeaderLevelEnum.H1">
                        <SchemaParameterListGroup Schema="Schema" SchemaParameter="context" Scope="@Scope" HeaderLevel="HTMLHeaderLevelEnum.H2"/>
                    </SchemaParameterListView>
                </Content>
                <Right>
                    @if (Schema.TimeActivated == null)
                    {
                        <SchemaParameterListCreate Scope="@Scope" SchemaID="ID" HeaderLevel="HTMLHeaderLevelEnum.H2"/>
                    }
                </Right>
            </MagazineFrame>
        }
    </div>
</Loader>

@code {

    [Parameter]
    public Guid ID { get; set; }

    private string Scope => $"{GetComponentName()}:{ID}";

    private bool IsLoading => StateSchema.Value.TryGetLoading(Scope, FeatureSchemaActionKind.Find, out bool value) && value;
    private EntitySchema? Schema => StateSchema.Value.TryGetFind(Scope, out EntitySchema? value) ? value : null;

    protected override void OnInitialized()
    {
        base.OnInitialized();

        Dispatcher.Dispatch(new FeatureSchemaReducers.FindAction(Scope, new() { ID = ID }));
    }
}
